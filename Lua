    obj.Box.Filled     = false
    obj.Name.Size      = 14
    obj.Name.Center    = true
    obj.Name.Outline   = true
end

local function RemoveESPForPlayer(player)
    local obj = ESPDrawings[player]
    if not obj then return end
    obj.Box:Remove()
    obj.Name:Remove()
    ESPDrawings[player] = nil
end

local function UpdateESP()
    local boxOn  = getgenv().ESP_Box_Enabled
    local nameOn = getgenv().ESP_Name_Enabled
    local maxDist= Opt("ESPMaxDist") or 300
    local boxCol = Options["ESPBoxColor"].Value  or Color3.new(1,1,1)
    local namCol = Options["ESPNameColor"].Value or Color3.new(1,1,1)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end

        if not boxOn and not nameOn then
            if ESPDrawings[player] then
                ESPDrawings[player].Box.Visible  = false
                ESPDrawings[player].Name.Visible = false
            end
            continue
        end

        local char = player.Character
        if not char then
            if ESPDrawings[player] then
                ESPDrawings[player].Box.Visible  = false
                ESPDrawings[player].Name.Visible = false
            end
            continue
        end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            if ESPDrawings[player] then
                ESPDrawings[player].Box.Visible  = false
                ESPDrawings[player].Name.Visible = false
            end
            continue
        end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local dist = (root.Position - Camera.CFrame.Position).Magnitude
        if dist > maxDist then
            if ESPDrawings[player] then
                ESPDrawings[player].Box.Visible  = false
                ESPDrawings[player].Name.Visible = false
            end
            continue
        end

        CreateESPForPlayer(player)
        local obj  = ESPDrawings[player]
        local head = char:FindFirstChild("Head") or root

        local headSP, headOn = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.7,0))
        local feetSP, feetOn = Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))

        if not headOn and not feetOn then
            obj.Box.Visible  = false
            obj.Name.Visible = false
            continue
        end

        local h2d = Vector2.new(headSP.X, headSP.Y)
        local f2d = Vector2.new(feetSP.X, feetSP.Y)

        local boxH = math.abs(h2d.Y - f2d.Y)
        local boxW = boxH * 0.65
        local boxX = h2d.X - boxW / 2

        if boxOn then
            obj.Box.Visible  = true
            obj.Box.Size     = Vector2.new(boxW, boxH)
            obj.Box.Position = Vector2.new(boxX, h2d.Y)
            obj.Box.Color    = boxCol
        else
            obj.Box.Visible = false
        end

        if nameOn then
            obj.Name.Visible  = true
            obj.Name.Text     = player.DisplayName
            obj.Name.Position = Vector2.new(h2d.X, h2d.Y - 16)
            obj.Name.Color    = namCol
        else
            obj.Name.Visible = false
        end
    end
end

