-- ========== ANTI-AIM ==========
local AntiAimSection = Combat:CreateSection("Anti-Aim")
local antiAimEnabled = false
local antiAimYaw = "none"
local antiAimPitch = "none"
local antiAimAngle = "none"
local antiAimCustomAngle = 0
local antiAimMinSpeed = 10
local antiAimMaxSpeed = 20
local antiAimMinAngle = 30
local antiAimMaxAngle = 60
local antiAimRandomAngle = false
local antiAimUnderground = false

local function updateAntiAim()
    if not antiAimEnabled or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local now = tick()
    local angleY = 0
    if antiAimYaw == "jitter" then
        angleY = (now % 0.5 < 0.25) and 90 or -90
    elseif antiAimYaw == "spinbot" then
        angleY = (now * 360) % 360
    elseif antiAimYaw == "random" then
        angleY = math.random(-180, 180)
    end
    local angleX = 0
    if antiAimPitch == "jitter" then
        angleX = (now % 0.5 < 0.25) and 45 or -45
    elseif antiAimPitch == "spinbot" then
        angleX = (now * 360) % 360
    elseif antiAimPitch == "random" then
        angleX = math.random(-80, 80)
    end
    local roll = 0
    if antiAimAngle == "tilt 45" then
        roll = 45
    elseif antiAimAngle == "tilt 90" then
        roll = 90
    elseif antiAimAngle == "upside down" then
        roll = 180
    elseif antiAimAngle == "custom" then
        roll = antiAimCustomAngle
    end
    if antiAimRandomAngle then
        roll = math.random(antiAimMinAngle, antiAimMaxAngle)
    end
    hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(math.rad(angleX), math.rad(angleY), math.rad(roll))
    if antiAimUnderground then
        hrp.CFrame = hrp.CFrame + Vector3.new(0, -50, 0)
    end
end

RunService.RenderStepped:Connect(updateAntiAim)

