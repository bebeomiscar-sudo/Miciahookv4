local animAutoRespawn = true
local animSpeed = 2
local animId = "96579993895076"
local animJitterId = "120819498172771"
local currentAnimTrack = nil

local function loadAnim(id, loop, speed)
    local char = LocalPlayer.Character
    local animator = char:FindFirstChildOfClass("Animator")
    if not animator then return end
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. id
    local track = animator:LoadAnimation(anim)
    track.Looped = loop
    track:AdjustSpeed(speed)
    return track
end

local function updateAnimation()
    if not animEnabled or not LocalPlayer.Character then
        if currentAnimTrack then currentAnimTrack:Stop() end
        return
    end
    if currentAnimTrack and currentAnimTrack.IsPlaying then
        currentAnimTrack:AdjustSpeed(animSpeed)
        return
    end
    local id = animJitter and animJitterId or animId
    currentAnimTrack = loadAnim(id, animLoop, animSpeed)
    if currentAnimTrack then currentAnimTrack:Play() end
end
RunService.RenderStepped:Connect(updateAnimation)

