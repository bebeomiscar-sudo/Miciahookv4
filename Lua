local ESPDrawings = {}

local function CreateESPForPlayer(player)
    if ESPDrawings[player] then return end
    ESPDrawings[player] = {
        Box  = Drawing.new("Square"),
        Name = Drawing.new("Text"),
    }
    local obj = ESPDrawings[player]
