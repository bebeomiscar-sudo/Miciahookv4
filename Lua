-- [[ RAGEBOT ]]
-- Fires BulletHandler.Fire for each enemy
-- Uses captured weapon data from real shots
-- ============================================================
local IsRagebotFiring = false
local LastRagebotTime = 0

local function NewBulletId()
    return math.random(100000, 999999)
end

local function FireAtEnemy(enemyData)
    if not CapturedNetwork then return end
    if not enemyData or not enemyData.Part then return end

    local origin    = Camera.CFrame.Position
    local part      = enemyData.Part
    local direction = (part.Position - origin).Unit
    local hits      = math.floor(Opt("RagebotHitsPerTarget") or 1)
    local delay     = (Opt("RagebotDelay") or 50) / 1000

    for i = 1, hits do
        -- Build data table from DEX BulletHandler.Fire signature
        local fireData = {
            Origin       = origin,
            VisualOrigin = origin,
            Direction    = direction,
            -- Safely get from captured data
            Force        = CapturedMisc and CapturedMisc.Force   or Vector3.new(0, 0, 0),
            Gravity      = CapturedMisc and CapturedMisc.Gravity or Vector3.new(0, -196.2, 0),
            BulletId     = NewBulletId(),
            Visuals      = CapturedVisuals or {
                BulletType = nil,
                HitEffect  = nil,
            },
            Logic        = CapturedLogic or {
                HitSound        = nil,
                HitMarker       = nil,
                IsExplosive     = false,
                ExplosionRadius = 0,
            },
            Network      = CapturedNetwork,
            Misc         = {
                AmmoCount  = CapturedMisc and CapturedMisc.AmmoCount  or 30,
                Spread     = 0,
                MaxAmmo    = CapturedMisc and CapturedMisc.MaxAmmo    or 30,
                ReloadTime = CapturedMisc and CapturedMisc.ReloadTime or 2,
                CamCFrame  = Camera.CFrame,
                NewSeed    = math.random(1, 999999),
            },
        }

        pcall(function()
            -- Call original to bypass our own hook
            OriginalBHFire(fireData)
        end)

        if delay > 0 and i < hits then
            task.wait(delay)
        end
    end
end

local function RunRagebot()
    if IsRagebotFiring then return end
    if not CapturedNetwork then
        warn("[creep.cc] Ragebot: No weapon data captured yet. Shoot first!")
        return
    end

    local bone      = Opt("RagebotBone")     or "Head"
    local teamChk   = Get("RagebotTeamCheck")
    local visChk    = Get("RagebotVisCheck")
    local maxDist   = Opt("RagebotMaxDist")  or 500
    local closest   = Get("RagebotClosestOnly")

    local enemies = GetEnemies(teamChk, visChk, bone, maxDist)
    if #enemies == 0 then return end

    -- Sort by distance if closest only
    if closest then
        table.sort(enemies, function(a, b) return a.Distance < b.Distance end)
        enemies = { enemies[1] }
    end

    IsRagebotFiring = true

    task.spawn(function()
        for _, enemyData in ipairs(enemies) do
            if not IsPlayerAlive(enemyData.Player) then continue end
            FireAtEnemy(enemyData)
        end
        IsRagebotFiring = false
    end)
end

-- Ragebot loop
task.spawn(function()
    while not bc.Unloaded do
        task.wait(0.016)

        local now      = tick()
        local interval = (Opt("RagebotInterval") or 200) / 1000

        if (getgenv().RagebotEnabled and now - LastRagebotTime >= interval)
            or _G.ForceKillAll then
            _G.ForceKillAll = false
            LastRagebotTime = now
            RunRagebot()
        end
    end
end)

