-- ============================================================
local ESPObjects = {}

local function CreateESP(player)
    if ESPObjects[player] then return end

    ESPObjects[player] = {
        Box      = Drawing.new("Square"),
        Name     = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBg = Drawing.new("Square"),
        HealthFg = Drawing.new("Square"),
    }

    local obj = ESPObjects[player]
    obj.Box.Thickness      = 1
    obj.Box.Filled         = false
    obj.Name.Size          = 13
    obj.Name.Center        = true
    obj.Name.Outline       = true
    obj.Distance.Size      = 12
    obj.Distance.Center    = true
    obj.Distance.Outline   = true
    obj.HealthBg.Filled    = true
    obj.HealthBg.Thickness = 0
    obj.HealthFg.Filled    = true
    obj.HealthFg.Thickness = 0
end

local function RemoveESP(player)
    local obj = ESPObjects[player]
    if not obj then return end
    for _, d in pairs(obj) do d:Remove() end
    ESPObjects[player] = nil
end

local function HideESP(player)
    local obj = ESPObjects[player]
    if not obj then return end
    for _, d in pairs(obj) do d.Visible = false end
end

local function UpdateESP()
    local espOn    = Get("ESPEnabled")
    local boxOn    = Get("ESPBox")
    local nameOn   = Get("ESPName")
    local distOn   = Get("ESPDistance")
    local hpOn     = Get("ESPHealth")
    local teamChk  = Get("ESPTeamCheck")
    local maxDist  = Opt("ESPMaxDist")  or 500
    local enmColor = Options["ESPEnemyColor"].Value or Color3.fromRGB(255,50,50)
    local teamColor= Options["ESPTeamColor"].Value  or Color3.fromRGB(50,255,50)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end

        if not espOn then
            HideESP(player)
            continue
        end

        if not IsAlive(player) then
            HideESP(player)
            continue
        end

        local char = player.Character
        if not char then HideESP(player) continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then HideESP(player) continue end

        local isTeam = LP.Team and player.Team == LP.Team
        if teamChk and isTeam then HideESP(player) continue end

        local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
        if dist3D > maxDist then HideESP(player) continue end

        CreateESP(player)
        local obj = ESPObjects[player]

        local head    = char:FindFirstChild("Head") or root
        local headSP, headOn = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.6, 0))
        local feetSP          = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))

        if not headOn then HideESP(player) continue end

        local col  = isTeam and teamColor or enmColor
        local h2d  = Vector2.new(headSP.X, headSP.Y)
        local f2d  = Vector2.new(feetSP.X, feetSP.Y)
        local boxH = math.abs(h2d.Y - f2d.Y)
        local boxW = boxH * 0.65
        local boxX = h2d.X - boxW / 2
        local boxY = h2d.Y

        -- Box
        obj.Box.Visible   = boxOn
        if boxOn then
            obj.Box.Size      = Vector2.new(boxW, boxH)
            obj.Box.Position  = Vector2.new(boxX, boxY)
            obj.Box.Color     = col
        end

        -- Name
        obj.Name.Visible  = nameOn
        if nameOn then
            obj.Name.Text     = player.DisplayName
            obj.Name.Position = Vector2.new(h2d.X, boxY - 16)
            obj.Name.Color    = col
        end

        -- Distance
        obj.Distance.Visible = distOn
        if distOn then
            obj.Distance.Text     = string.format("[%.0f]", dist3D)
            obj.Distance.Position = Vector2.new(h2d.X, f2d.Y + 2)
            obj.Distance.Color    = Color3.new(1, 1, 1)
        end

        -- Health bar
        local hum = char:FindFirstChildOfClass("Humanoid")
        obj.HealthBg.Visible = hpOn
        obj.HealthFg.Visible = hpOn
        if hpOn and hum then
            local maxHp  = hum.MaxHealth
            local curHp  = hum.Health
            local ratio  = math.clamp(curHp / math.max(maxHp, 1), 0, 1)
            local barH   = boxH * ratio
            local barX   = boxX - 6
            local barW   = 3

            -- Background (empty)
            obj.HealthBg.Size     = Vector2.new(barW, boxH)
            obj.HealthBg.Position = Vector2.new(barX, boxY)
            obj.HealthBg.Color    = Color3.fromRGB(50, 0, 0)

            -- Foreground (health)
            obj.HealthFg.Size     = Vector2.new(barW, barH)
            obj.HealthFg.Position = Vector2.new(barX, boxY + boxH - barH)
            obj.HealthFg.Color    = Color3.fromHSV(ratio * 0.33, 1, 1)
        end
    end
end

