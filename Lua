-- ============================================================
local OrbitParts  = {}
local OrbitAngle  = 0
local OrbitFolder = nil

_G.OrbitCleanup = function()
    for _, data in ipairs(OrbitParts) do
        if data.Part and data.Part.Parent then data.Part:Destroy() end
    end
    table.clear(OrbitParts)
    if OrbitFolder and OrbitFolder.Parent then OrbitFolder:Destroy(); OrbitFolder = nil end
    OrbitStatusLbl:SetText('Orbit Parts: 0')
end

_G.OrbitSetVisible = function(visible)
    local transp = visible and (Opt("OrbitTransparency") or 0)/100 or 1
    for _, data in ipairs(OrbitParts) do
        if data.Part and data.Part.Parent then data.Part.Transparency = transp end
    end
end

_G.OrbitRebuild = function(count)
    _G.OrbitCleanup()
    if not Get("OrbitEnabled") then return end
    OrbitFolder = Instance.new("Folder")
    OrbitFolder.Name="LogicOrbitAura"; OrbitFolder.Parent=workspace
    local shape=Opt("OrbitShape") or "Ball"
    local shapeEnum=shape=="Ball" and Enum.PartType.Ball or shape=="Cylinder" and Enum.PartType.Cylinder or Enum.PartType.Block
    local glowOn=Get("OrbitGlow"); local visible=Get("OrbitVisible")
    local transp=visible and (Opt("OrbitTransparency") or 0)/100 or 1
    local sz=Opt("OrbitSize") or 1
    local col=Options["OrbitColor"] and Options["OrbitColor"].Value or Color3.fromRGB(0,200,255)
    for i=1,count do
        local part=Instance.new("Part")
        part.Name="_OrbitPart_"..i; part.Anchored=true
        part.CanCollide=false; part.CanQuery=false; part.CanTouch=false
        part.CastShadow=false; part.Massless=true; part.Shape=shapeEnum
        part.Size=Vector3.new(sz,sz,sz); part.Transparency=transp
        part.Material=glowOn and Enum.Material.Neon or Enum.Material.SmoothPlastic
        part.Color=col; part.Parent=OrbitFolder
        if glowOn then
            local pl=Instance.new("PointLight")
            pl.Brightness=2; pl.Range=8; pl.Color=col; pl.Parent=part
        end
        table.insert(OrbitParts,{
            Part=part, AngleOffset=(2*math.pi/count)*(i-1),
            Layer=(i%2==0) and 1 or -1, Index=i, Total=count,
        })
    end
    OrbitStatusLbl:SetText('Orbit Parts: '..count)
end

local function GetOrbitPosition(data, angle, rootCF, radius, height, tilt)
    local a=angle+data.AngleOffset
    local pat=Opt("OrbitPattern") or "Ring"
    local lx,ly,lz
    if pat=="Ring" then lx=math.cos(a)*radius;ly=height;lz=math.sin(a)*radius
    elseif pat=="Double Ring" then lx=math.cos(a)*radius;ly=height+data.Layer*1.5;lz=math.sin(a)*radius
    elseif pat=="Helix" then local ht=(data.Index/data.Total)*2*math.pi;lx=math.cos(a)*radius;ly=height+math.sin(ht)*2;lz=math.sin(a)*radius
    elseif pat=="Figure 8" then lx=math.sin(a)*radius;ly=height+math.sin(a*2)*1.5;lz=math.cos(a)*radius
    elseif pat=="Spiral" then local r=radius*(.5+((math.sin(tick()*2+data.AngleOffset)+1)/2)*.5);lx=math.cos(a)*r;ly=height;lz=math.sin(a)*r
    end
    return (rootCF*CFrame.Angles(math.rad(tilt),0,0)*CFrame.new(lx,ly,lz)).Position
end

local function GetOrbitColor(data,angle)
    if Get("OrbitRainbow") then return Color3.fromHSV(((tick()*.5+data.AngleOffset/(2*math.pi))%1),1,1) end
    local c1=Options["OrbitColor"] and Options["OrbitColor"].Value or Color3.fromRGB(0,200,255)
    local c2=Options["OrbitColor2"] and Options["OrbitColor2"].Value or Color3.fromRGB(255,0,200)
    return c1:Lerp(c2,(math.sin(angle+data.AngleOffset)+1)/2)
end

