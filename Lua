function Library:SafeCallback(f, ...)
    if (not f) then return; end;
    local success, event = pcall(f, ...);
    if not success then
        local _, i = event:find(":%d+: ");
        if i then return Library:Notify(event:sub(i + 1), 3); end;
        return Library:Notify(event, 3);
    end;
end;

