-- [[ BULLET TRACER ]]
-- ============================================================
local TracerLines = {}

local function SpawnTracer(fromPos, toPos)
    if not Get("TracerEnabled") then return end

    local screenFrom, onFrom = Camera:WorldToViewportPoint(fromPos)
    local screenTo,   onTo   = Camera:WorldToViewportPoint(toPos)
    if not onFrom and not onTo then return end

    local col      = Options["TracerColor"].Value    or Color3.fromRGB(0,255,255)
    local thick    = Opt("TracerThickness") or 2
    local lifetime = (Opt("TracerLifetime") or 500) / 1000
    local fade     = Get("TracerFade")

    local line         = Drawing.new("Line")
    line.Visible       = true
    line.From          = Vector2.new(screenFrom.X, screenFrom.Y)
    line.To            = Vector2.new(screenTo.X, screenTo.Y)
    line.Color         = col
    line.Thickness     = thick
    line.Transparency  = 0

    task.spawn(function()
        if fade then
            local steps   = 20
            local stepT   = lifetime / steps
            for i = 1, steps do
                if not line then break end
                line.Transparency = i / steps
                task.wait(stepT)
            end
        else
            task.wait(lifetime)
        end
        line:Remove()
    end)
end

-- Hook BulletHandler fire completions via workspace projectile detection
workspace.DescendantAdded:Connect(function(obj)
    if not Get("TracerEnabled") then return end
    if not obj:IsA("BasePart") then return end
    task.defer(function()
        if not obj or not obj.Parent then return end
        local vel = obj.AssemblyLinearVelocity.Magnitude
        if vel > 30 then
            local camPos = Camera.CFrame.Position
            SpawnTracer(camPos, obj.Position)
        end
    end)
end)

