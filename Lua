-- ============================================================
-- DETECTION KEYWORDS
-- ============================================================
local SLING_KEYWORDS  = {"sling","pebble","stone","proj","ball","rock","shot","core","bounc"}
local BOW_KEYWORDS    = {"arrow","bow","bolt","shaft","quiver","dart","fletching"}
local DAGGER_KEYWORDS = {"dagger","knife","blade","shuriken","throwable","thrown","kunai"}

local OWNER_SCAN_RADIUS = 9999 -- infinite range: scan entire workspace for owner

local function NameHasKeyword(name, keywords, extras)
    local lower = name:lower()
    for _, kw in ipairs(keywords) do if lower:find(kw,1,true) then return true end end
    for _, n  in ipairs(extras)   do if lower:find(n:lower(),1,true) then return true end end
    return false
end

local function HasProjAttribute(part)
    local ok, v = pcall(function()
        return part:GetAttribute("ProjectileOwner")
            or part:GetAttribute("Owner")
            or part:GetAttribute("Shooter")
            or part:GetAttribute("IsProjectile")
            or part:GetAttribute("WeaponType")
    end)
    return ok and v ~= nil
end

local function PhysicsLooksLikeProjectile(part, velFloor)
    if not part:IsA("BasePart") then return false end
    local sz = part.Size
    if sz.X > 6 or sz.Y > 6 or sz.Z > 6 then return false end
    if part.AssemblyLinearVelocity.Magnitude < (velFloor or 55) then return false end
    if part.Anchored then return false end
    local model = part:FindFirstAncestorOfClass("Model")
    if model and model:FindFirstChildOfClass("Humanoid") then return false end
    return true
end

local function NearPlayerWithTool(part, toolKeywords)
    for _, pl in ipairs(Players:GetPlayers()) do
        local ch2 = pl.Character; if not ch2 then continue end
        local root = ch2:FindFirstChild("HumanoidRootPart"); if not root then continue end
        local tool = ch2:FindFirstChildOfClass("Tool")
        if tool and NameHasKeyword(tool.Name, toolKeywords, {}) then return true, pl end
    end
    return false, nil
end

local function ClassifyProjectile(part)
    if not part:IsA("BasePart") then return nil end
    local wt = nil; pcall(function() wt = part:GetAttribute("WeaponType") end)
    if wt then
        local wtl = tostring(wt):lower()
        if wtl:find("sling") or wtl:find("pebble") then return "sling"  end
        if wtl:find("bow")   or wtl:find("arrow")  then return "bow"    end
        if wtl:find("dag")   or wtl:find("knife")  then return "dagger" end
    end
    if NameHasKeyword(part.Name, SLING_KEYWORDS,  ExtraSlingNames)  then return "sling"  end
    if NameHasKeyword(part.Name, BOW_KEYWORDS,    ExtraBowNames)    then return "bow"    end
    if NameHasKeyword(part.Name, DAGGER_KEYWORDS, ExtraDaggerNames) then return "dagger" end

    local sFloor = Opt("SlingVelocityThreshold")  or 80
    local bFloor = Opt("BowVelocityThreshold")    or 120
    local dFloor = Opt("DaggerVelocityThreshold") or 60

    if PhysicsLooksLikeProjectile(part, sFloor) then
        local near = NearPlayerWithTool(part, SLING_KEYWORDS); if near then return "sling" end
    end
    if PhysicsLooksLikeProjectile(part, bFloor) then
        local near = NearPlayerWithTool(part, BOW_KEYWORDS); if near then return "bow" end
    end
    if PhysicsLooksLikeProjectile(part, dFloor) then
        local near = NearPlayerWithTool(part, DAGGER_KEYWORDS); if near then return "dagger" end
    end
    if HasProjAttribute(part) and PhysicsLooksLikeProjectile(part, 55) then return "sling" end
    return nil

    -- HITBOX TAB also intercepts ALL weapons if HitboxAllWeapons is on
end

-- ============================================================
-- OWNER DETECTION â€” infinite range, attribute-first
-- ============================================================
local function DetectOwner(proj)
    local uid = nil
    pcall(function()
        uid = proj:GetAttribute("ProjectileOwner")
             or proj:GetAttribute("Owner")
             or proj:GetAttribute("Shooter")
    end)
    if uid then
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl.UserId == uid or pl.Name == uid then return pl end
        end
    end
    -- Proximity â€” scan all players regardless of distance (infinite range mode)
    local best, bd = nil, math.huge
    for _, pl in ipairs(Players:GetPlayers()) do
        local ch2 = pl.Character; if not ch2 then continue end
        local r   = ch2:FindFirstChild("HumanoidRootPart"); if not r then continue end
        local d   = (r.Position - proj.Position).Magnitude
        if d < bd then bd = d; best = pl end
    end
    return best
end

-- ============================================================
-- MOVEMENT EFFECTS
-- ============================================================
local function GetNearestEnemy(fromPos, exclude, teamCheck)
    -- Infinite range: maxDist = math.huge
    local best, bd = nil, math.huge
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LP then continue end
        if exclude and pl == exclude then continue end
        if teamCheck and LP.Team and pl.Team == LP.Team then continue end
        local ch2 = pl.Character; if not ch2 then continue end
        local hum = ch2:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local head = ch2:FindFirstChild("Head") or ch2:FindFirstChild("HumanoidRootPart")
        if not head then continue end
        local d = (head.Position - fromPos).Magnitude
        if d < bd then bd = d; best = head end
    end
    return best
end

local function PredictPos(targetPart, proj, speed)
    local dist = (targetPart.Position - proj.Position).Magnitude
    local t1   = dist / math.max(speed, 1)
    local vel  = targetPart.AssemblyLinearVelocity
    local p1   = targetPart.Position + vel * t1
    local d2   = (p1 - proj.Position).Magnitude
    local t2   = d2 / math.max(speed, 1)
    return targetPart.Position + vel * t2
end

local function DoHoming(part, owner, spd, predict, teamCheck, redirectToOwner, ownHom)
    if owner == LP and not ownHom then return end
    local target = nil
    if redirectToOwner and owner and owner ~= LP and owner.Character then
        target = owner.Character:FindFirstChild("Head") or owner.Character:FindFirstChild("HumanoidRootPart")
    end
    if not target then target = GetNearestEnemy(part.Position, LP, teamCheck) end
    if not target then return end
    local tPos = predict and PredictPos(target, part, spd) or target.Position
    local dir  = tPos - part.Position
    if dir.Magnitude < 0.01 then return end
    pcall(function() part.AssemblyLinearVelocity = dir.Unit * spd end)
end

local function DoInvisible(part)
    pcall(function()
        part.Transparency = 1; part.CanCollide = false
        part.CanQuery = false; part.CanTouch = false; part.CastShadow = false
        for _, c in ipairs(part:GetDescendants()) do
            if c:IsA("ParticleEmitter") or c:IsA("PointLight") or c:IsA("SpotLight") then c.Enabled = false
            elseif c:IsA("Sound") then c:Stop()
            elseif c:IsA("Trail") then c.Enabled = false
            end
        end
    end)
end

local function DoNullify(part)
    task.defer(function()
        if part and part.Parent then pcall(function() part:Destroy() end) end
    end)
end

-- ============================================================
-- PROJECTILE TRACKING
-- ============================================================
local SlingActive  = {}; local SlingOwners  = {}
local BowActive    = {}; local BowOwners    = {}
local DaggerActive = {}; local DaggerOwners = {}

local function ProcessProjectile(part)
    local kind = ClassifyProjectile(part)

    -- Hitbox expander catches anything if AllWeapons is on
    if not kind and Get("HitboxEnabled") and Get("HitboxAllWeapons") then
        if PhysicsLooksLikeProjectile(part, 40) then kind = "sling" end
    end

    if not kind then return end

    local active, owners, prefix
    if     kind == "sling"  then active=SlingActive;  owners=SlingOwners;  prefix="Sling"
    elseif kind == "bow"    then active=BowActive;    owners=BowOwners;    prefix="Bow"
    elseif kind == "dagger" then active=DaggerActive; owners=DaggerOwners; prefix="Dagger"
    end

    if active[part] then return end
    active[part] = { SpawnTime = tick(), Done = false, Kind = kind }

    local rdKey  = prefix.."RandomDelay"
    local mrdKey = prefix.."MaxRandomDelay"
    local hdKey  = prefix.."HomingDelay"
    local baseDelay = Get(rdKey) and (math.random()*((Opt(mrdKey) or 16)/1000)) or 0
    local homDelay  = (Opt(hdKey) or 3)/1000

    task.delay(baseDelay + homDelay, function()
        if not part or not part.Parent then active[part]=nil; return end
        local owner = DetectOwner(part)
        owners[part] = owner

        if not Get(prefix.."BypassEnabled") then
            if active[part] then active[part].Done = true end
            return
        end

        local method   = Opt(prefix.."BypassMethod") or "Combined"
        local spd      = Opt(prefix.."HomingSpeed") or 999
        local predict  = Get(prefix.."HomingPrediction")
        local team     = Get(prefix.."TeamCheck")
        local redir    = Get(prefix.."RedirectToOwner")
        local ownHom   = Get(prefix.."OwnProjHoming")

        pcall(function()
            if owner == LP and not ownHom then
                -- own projectile â€” just let hitbox expander handle silent aim
            else
                if method == "Combined" then
                    if Get(prefix.."HomingEnabled") and owner ~= LP then DoHoming(part, owner, spd, predict, team, redir, ownHom) end
                    if Get(prefix.."InvisEnabled")  and owner ~= LP then DoInvisible(part) end
                    if Get(prefix.."NullifyEnabled") and owner ~= LP then DoNullify(part) end
                elseif method == "Homing"    then DoHoming(part, owner, spd, predict, team, redir, ownHom)
                elseif method == "Invisible" then DoInvisible(part)
                elseif method == "Nullify"   then DoNullify(part)
                end
            end
        end)

        if active[part] then active[part].Done = true end
    end)
end

