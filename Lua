local ESPDrawings  = {}

local function CreateESPObj(player)
    if ESPDrawings[player] then return end

    ESPDrawings[player] = {
        Box      = Drawing.new("Square"),
        Name     = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBg = Drawing.new("Square"),
        HealthFg = Drawing.new("Square"),
    }

    local o = ESPDrawings[player]
    o.Box.Filled         = false
    o.Name.Size          = 13
    o.Name.Center        = true
    o.Name.Outline       = true
    o.Name.OutlineColor  = Color3.new(0,0,0)
    o.Distance.Size      = 12
    o.Distance.Center    = true
    o.Distance.Outline   = true
    o.Distance.OutlineColor = Color3.new(0,0,0)
    o.HealthBg.Filled    = true
    o.HealthBg.Thickness = 0
    o.HealthFg.Filled    = true
    o.HealthFg.Thickness = 0
end

local function HideESPObj(player)
    local o = ESPDrawings[player]
    if not o then return end
    o.Box.Visible      = false
    o.Name.Visible     = false
    o.Distance.Visible = false
    o.HealthBg.Visible = false
    o.HealthFg.Visible = false
end

local function RemoveESPObj(player)
    local o = ESPDrawings[player]
    if not o then return end
    for _, d in pairs(o) do
        pcall(function() d:Remove() end)
    end
    ESPDrawings[player] = nil
end

local function UpdateESP()
    local espOn    = Get("ESPEnabled")
    local boxOn    = Get("ESPBox")
    local nameOn   = Get("ESPName")
    local distOn   = Get("ESPDistance")
    local hpOn     = Get("ESPHealth")
    local teamChk  = Get("ESPTeamCheck")
    local maxDist  = Opt("ESPMaxDist")     or 500
    local boxThick = Opt("ESPBoxThickness")or 1
    local enmCol   = Options["ESPEnemyColor"].Value or Color3.fromRGB(255,60,60)
    local teamCol  = Options["ESPTeamColor"].Value  or Color3.fromRGB(60,255,60)
    local nameCol  = Options["ESPNameColor"].Value  or Color3.new(1,1,1)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end

        if not espOn then
            HideESPObj(player)
            continue
        end

        if not IsPlayerAlive(player) then
            HideESPObj(player)
            continue
        end

        local char = player.Character
        if not char then HideESPObj(player) continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then HideESPObj(player) continue end

        -- Distance check
        local dist3D = (root.Position - Camera.CFrame.Position).Magnitude
        if dist3D > maxDist then HideESPObj(player) continue end

        -- Team check
        local isTeam = LP.Team ~= nil and player.Team == LP.Team
        if teamChk and isTeam then HideESPObj(player) continue end

        -- Get screen positions
        local head    = char:FindFirstChild("Head") or root
        local headTop = head.Position + Vector3.new(0, 0.7, 0)
        local feetPos = root.Position - Vector3.new(0, 3.2, 0)

        local headSP, headOnScreen = Camera:WorldToViewportPoint(headTop)
        local feetSP, _            = Camera:WorldToViewportPoint(feetPos)

        -- Must be on screen
        if not headOnScreen or headSP.Z <= 0 then
            HideESPObj(player)
            continue
        end

        CreateESPObj(player)
        local o   = ESPDrawings[player]
        local col = isTeam and teamCol or enmCol

        local h2d  = Vector2.new(headSP.X, headSP.Y)
        local f2d  = Vector2.new(feetSP.X, feetSP.Y)
        local boxH = math.abs(f2d.Y - h2d.Y)
        local boxW = boxH * 0.6

        -- Ensure minimum size
        if boxH < 5 then HideESPObj(player) continue end

        local boxX = h2d.X - boxW * 0.5
        local boxY = h2d.Y

        -- Box
        o.Box.Visible   = boxOn
        if boxOn then
            o.Box.Size      = Vector2.new(boxW, boxH)
            o.Box.Position  = Vector2.new(boxX, boxY)
            o.Box.Color     = col
            o.Box.Thickness = boxThick
        end

        -- Name
        o.Name.Visible = nameOn
        if nameOn then
            o.Name.Text     = player.DisplayName
            o.Name.Position = Vector2.new(h2d.X, boxY - 16)
            o.Name.Color    = nameCol
        end

        -- Distance
        o.Distance.Visible = distOn
        if distOn then
            o.Distance.Text     = string.format("[%d]", math.floor(dist3D))
            o.Distance.Position = Vector2.new(h2d.X, f2d.Y + 3)
            o.Distance.Color    = Color3.new(1, 1, 1)
        end

        -- Health bar
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hpOn and hum then
            local ratio = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
            local barH  = boxH * ratio
            local barX  = boxX - 5
            local barW  = 3

            o.HealthBg.Visible  = true
            o.HealthBg.Size     = Vector2.new(barW, boxH)
            o.HealthBg.Position = Vector2.new(barX, boxY)
            o.HealthBg.Color    = Color3.fromRGB(40, 0, 0)

            o.HealthFg.Visible  = true
            o.HealthFg.Size     = Vector2.new(barW, barH)
            o.HealthFg.Position = Vector2.new(barX, boxY + boxH - barH)
            -- Green → Yellow → Red by health ratio
            o.HealthFg.Color    = Color3.fromHSV(ratio * 0.35, 1, 1)
        else
            o.HealthBg.Visible = false
            o.HealthFg.Visible = false
        end
    end
end

