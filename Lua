local ChammedChars  = {}
local OrigCharData  = {}

local function ApplyChamsToChar(char)
    if not char:FindFirstChild("HumanoidRootPart") then return end

    if not OrigCharData[char] then
        OrigCharData[char] = {}
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                OrigCharData[char][obj] = {
                    Color        = obj.Color,
                    Material     = obj.Material,
                    Transparency = obj.Transparency,
                }
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                OrigCharData[char][obj] = { Transparency = obj.Transparency }
            elseif obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("BodyColors") or obj:IsA("Accessory") then
                OrigCharData[char][obj] = { Parent = obj.Parent }
            end
        end
    end

    -- Apply neon chams visible
    for _, obj in ipairs(char:GetDescendants()) do
        if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and obj.Transparency < 1 then
            obj.Material     = Enum.Material.Neon
            obj.Color        = getgenv().ChamsColor or Color3.fromRGB(170, 170, 255)
            obj.Transparency = 0.3
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        elseif obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("BodyColors") or obj:IsA("Accessory") then
            obj.Parent = nil
        end
    end

    -- Add highlight for wallhack (through-wall)
    if not char:FindFirstChild("ChamsHighlight") then
        local h             = Instance.new("Highlight")
        h.Name              = "ChamsHighlight"
        h.FillTransparency  = 0
        h.OutlineTransparency = 1
        h.Enabled           = true
        h.FillColor         = getgenv().ThroughWallChamsColor or Color3.fromRGB(170, 100, 255)
        h.Adornee           = char
        h.Parent            = char
    end

    ChammedChars[char] = true
end

local function RemoveChamsFromChar(char)
    if not OrigCharData[char] then return end

    for obj, data in pairs(OrigCharData[char]) do
        if obj and obj.Parent then
            pcall(function()
                if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                    obj.Color        = data.Color
                    obj.Material     = data.Material
                    obj.Transparency = data.Transparency
                elseif obj:IsA("Decal") or obj:IsA("Texture") then
                    obj.Transparency = data.Transparency
                else
                    obj.Parent = data.Parent
                end
            end)
        end
    end

    local h = char:FindFirstChild("ChamsHighlight")
    if h then h:Destroy() end

    OrigCharData[char]  = nil
    ChammedChars[char]  = nil
end

