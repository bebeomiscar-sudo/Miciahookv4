end

local function updateESP()
    if not espMaster then
        for _, drawings in pairs(espDrawings) do
            for _, d in pairs(drawings) do
                if d then d.Visible = false end
            end
        end
        return
    end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local size = 100 / pos.Z
                local boxPos = Vector2.new(pos.X - size/2, pos.Y - size)
                if espBoxes then
                    createDrawing(player, "box")
                    espDrawings[player].box.Color = espBoxColor
                    espDrawings[player].box.Size = Vector2.new(size, size*1.5)
                    espDrawings[player].box.Position = boxPos
                    espDrawings[player].box.Visible = true
                end
                if espFill then
                    createDrawing(player, "fill")
                    espDrawings[player].fill.Color = espFillColor
                    espDrawings[player].fill.Transparency = espFillTrans
                    espDrawings[player].fill.Size = Vector2.new(size, size*1.5)
                    espDrawings[player].fill.Position = boxPos
                    espDrawings[player].fill.Visible = true
                end
                if espNames then
                    createDrawing(player, "name")
                    espDrawings[player].name.Color = espNameColor
                    espDrawings[player].name.Position = Vector2.new(pos.X, pos.Y - size*1.5 - 15)
                    espDrawings[player].name.Text = player.Name
                    espDrawings[player].name.Visible = true
                end
                if espDistance then
                    createDrawing(player, "distance")
                    local dist = (hrp.Position - Camera.CFrame.Position).Magnitude
                    espDrawings[player].dist.Color = espDistColor
                    espDrawings[player].dist.Position = Vector2.new(pos.X, pos.Y - size*1.5 - 2)
                    espDrawings[player].dist.Text = string.format("%.1fm", dist)
                    espDrawings[player].dist.Visible = true
                end
                if espHealth then
                    createDrawing(player, "health")
                    local hum = player.Character:FindFirstChildOfClass("Humanoid")
                    if hum then
                        local healthPercent = hum.Health / hum.MaxHealth
                        local healthHeight = size * 1.5 * healthPercent
                        espDrawings[player].health.From = Vector2.new(pos.X - size/2 - 5, pos.Y - size + size*1.5 - healthHeight)
                        espDrawings[player].health.To = Vector2.new(pos.X - size/2 - 5, pos.Y - size + size*1.5)
                        espDrawings[player].health.Color = Color3.fromHSV(0.3 * healthPercent, 1, 1)
                        espDrawings[player].health.Visible = true
                    end
                end
                if espTracers then
                    createDrawing(player, "tracer")
                    espDrawings[player].tracer.Color = espTracerColor
                    espDrawings[player].tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    espDrawings[player].tracer.To = Vector2.new(pos.X, pos.Y)
                    espDrawings[player].tracer.Visible = true
                end
                -- Skeleton (simplified: head to torso to limbs)
                if espSkeleton then
                    createDrawing(player, "skeleton")
                    local head = player.Character:FindFirstChild("Head")
                    local torso = player.Character:FindFirstChild("UpperTorso") or player.Character:FindFirstChild("Torso")
                    if head and torso then
                        local hpos, _ = Camera:WorldToViewportPoint(head.Position)
                        local tpos, _ = Camera:WorldToViewportPoint(torso.Position)
                        if not espDrawings[player].skeleton.line then
                            espDrawings[player].skeleton.line = Drawing.new("Line")
                            espDrawings[player].skeleton.line.Thickness = espSkelThick
                        end
                        espDrawings[player].skeleton.line.From = Vector2.new(hpos.X, hpos.Y)
                        espDrawings[player].skeleton.line.To = Vector2.new(tpos.X, tpos.Y)
                        espDrawings[player].skeleton.line.Color = espSkelColor
                        espDrawings[player].skeleton.line.Visible = true
                    end
                end
            else
                if espDrawings[player] then
                    for _, d in pairs(espDrawings[player]) do
                        if d then d.Visible = false end
                    end
                end
            end
        end
    end
end
