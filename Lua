-- [[ TRIGGERBOT ]]
-- ============================================================
local TriggerOnCooldown = false
local LastTrigger       = 0

local function RunTriggerbot()
    if not getgenv().TRIGGER_Enabled then return end
    if TriggerOnCooldown then return end

    local radius = getgenv().TriggerRadius or 10
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = player.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        for _, part in ipairs(char:GetDescendants()) do
            if not (part:IsA("BasePart") or part:IsA("MeshPart")) then continue end

            local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
            if not onScreen then continue end

            if (Vector2.new(sp.X, sp.Y) - center).Magnitude <= radius then
                TriggerOnCooldown = true
                local clickDelay  = (Opt("TriggerDelay") or 16) / 1000

                task.delay(clickDelay, function()
                    pcall(function()
                        if mouse1click then mouse1click() end
                    end)
                    pcall(function()
                        if mousebuttonclick then mousebuttonclick(1) end
                    end)
                    task.delay(0.05, function()
                        TriggerOnCooldown = false
                    end)
                end)
                return
            end
        end
    end
end

