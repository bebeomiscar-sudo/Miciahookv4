-- 13. KEYBIND LIST UI
-- ============================================
local kbList = getgenv().InstanceKeybindList or {}
getgenv().InstanceKeybindList = kbList

local function buildKbListUi()
    if kbList.gui then return end
    local parent = (gethui and gethui()) or game:GetService("CoreGui")
    local gui = Instance.new("ScreenGui")
    gui.Name = "instance_keybind_list"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    gui.DisplayOrder = 80
    gui.Enabled = false
    gui.Parent = parent
    
    local outer = Instance.new("Frame")
    outer.Size = UDim2.fromOffset(160, 100)
    outer.Position = UDim2.new(0, 10, 0.5, -50)
    outer.BackgroundColor3 = Color3.new(0, 0, 0)
    outer.BorderSizePixel = 0
    outer.Active = true
    outer.Draggable = true
    outer.Parent = gui
    
    local inner = Instance.new("Frame")
    inner.Size = UDim2.new(1, -2, 1, -2)
    inner.Position = UDim2.fromOffset(1, 1)
    inner.BorderSizePixel = 1
    inner.BorderMode = Enum.BorderMode.Inset
    inner.Parent = outer
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 28)
    title.Text = "keybinds"
    title.TextXAlignment = Enum.TextXAlignment.Center
    title.BackgroundTransparency = 1
    title.Parent = inner
    
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -8, 1, -36)
    scroll.Position = UDim2.new(0, 4, 0, 32)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ScrollBarThickness = 3
    scroll.Parent = inner
    
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.Parent = scroll
    
    kbList.gui = gui
    kbList.outer = outer
    kbList.inner = inner
    kbList.scroll = scroll
    kbList.layout = layout
    kbList.title = title
end

local function syncKbListVisible()
    buildKbListUi()
    local want = Toggles.KeybindVisible and Toggles.KeybindVisible.Value
    local open = Window and Window.Holder and Window.Holder.Visible
    kbList.visible = want == true and not open
    if kbList.gui then
        kbList.gui.Enabled = kbList.visible
    end
end

getgenv().syncKbListVisible = syncKbListVisible

Window.Holder:GetPropertyChangedSignal("Visible"):Connect(syncKbListVisible)
task.defer(syncKbListVisible)

