-- [[ BULLET TRACER - DRAWING BASED ]]
-- Uses ProjectileRender hook to intercept projectile data
-- Spawns Drawing.Line from chosen origin to hit point
-- ============================================================
local ActiveTracers = {}

local function SpawnTracer(originWorldPos, endWorldPos)
    if not Get("TracerEnabled") then return end

    local col      = Options["TracerColor"].Value    or Color3.fromRGB(0,255,255)
    local thick    = Opt("TracerThickness")           or 2
    local lifetime = (Opt("TracerLifetime") or 500)  / 1000
    local fade     = Get("TracerFade")
    local fromMode = Opt("TracerFrom") or "Camera"

    -- Determine screen start point
    local startVP
    if fromMode == "Bottom Screen" then
        startVP = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
    else
        -- Camera center
        local camSP = Camera:WorldToViewportPoint(originWorldPos)
        startVP = Vector2.new(camSP.X, camSP.Y)
    end

    -- End point
    local endSP, onScreen = Camera:WorldToViewportPoint(endWorldPos)
    if not onScreen or endSP.Z <= 0 then return end

    local endVP = Vector2.new(endSP.X, endSP.Y)

    local line         = Drawing.new("Line")
    line.Visible       = true
    line.From          = startVP
    line.To            = endVP
    line.Color         = col
    line.Thickness     = thick
    line.Transparency  = 0

    task.spawn(function()
        if fade then
            local steps = 20
            local stepT = lifetime / steps
            for i = 1, steps do
                if not line then break end
                line.Transparency = i / steps
                task.wait(stepT)
            end
        else
            task.wait(lifetime)
        end
        pcall(function() line:Remove() end)
    end)
end

-- Hook ProjectileRender to capture bullet data for tracers
if ProjectileRender and ProjectileRender.Cast and not PRHooked then
    OriginalPRCast = ProjectileRender.Cast

    ProjectileRender.Cast = function(self, data)
        -- Spawn drawing tracer from captured data
        if Get("TracerEnabled") and data then
            local origin   = data.Origin   or Camera.CFrame.Position
            local endpoint = data.Endpoint or (origin + Vector3.new(0, 0, -100))
            task.spawn(function()
                SpawnTracer(origin, endpoint)
            end)
        end

        -- Disable original tracer if toggle is on
        if Get("TracerEnabled") and Get("TracerDisableOriginal") then
            return
        end

        return OriginalPRCast(self, data)
    end

    PRHooked = true
    print("[creep.cc] ProjectileRender.Cast hooked for tracers")
end

