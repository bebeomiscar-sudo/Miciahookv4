-- [[ CHAMS SYSTEM - FIXED ]]
-- Applies to ALL players properly
-- Stores original data per character
-- ============================================================
local ChammedChars = {}   -- [char] = { [part] = originalData }
local ChamsHighlights = {} -- [char] = Highlight instance

local function GetMaterialEnum(style)
    local map = {
        Neon          = Enum.Material.Neon,
        Glass         = Enum.Material.Glass,
        ForceField    = Enum.Material.ForceField,
        CrackedLava   = Enum.Material.CrackedLava,
        SmoothPlastic = Enum.Material.SmoothPlastic,
    }
    return map[style] or Enum.Material.Neon
end

local function SaveAndApplyChams(char)
    if not char then return end
    if not char:FindFirstChild("HumanoidRootPart") then return end

    -- Save original data
    if not ChammedChars[char] then
        ChammedChars[char] = {}
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                ChammedChars[char][obj] = {
                    Color        = obj.Color,
                    Material     = obj.Material,
                    Transparency = obj.Transparency,
                }
            end
        end
    end

    local style   = Opt("ChamsStyle")        or "Neon"
    local col     = Options["ChamsBodyColor"].Value or Color3.fromRGB(0,200,255)
    local transp  = (Opt("ChamsTransparency") or 30) / 100
    local matEnum = GetMaterialEnum(style)

    -- Apply to all body parts
    for obj, _ in pairs(ChammedChars[char]) do
        if obj and obj.Parent then
            pcall(function()
                obj.Material     = matEnum
                obj.Color        = col
                obj.Transparency = transp
            end)
        end
    end

    -- Wallhack highlight
    if not ChamsHighlights[char] then
        local hl = Instance.new("Highlight")
        hl.Name                = "_ChamHL"
        hl.FillColor           = Options["ChamsWallColor"].Value or Color3.fromRGB(255,0,100)
        hl.FillTransparency    = (Opt("ChamsWallTransp") or 40) / 100
        hl.OutlineTransparency = 1
        hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee             = char
        hl.Parent              = char
        ChamsHighlights[char]  = hl
    else
        local hl = ChamsHighlights[char]
        if hl and hl.Parent then
            hl.FillColor        = Options["ChamsWallColor"].Value or Color3.fromRGB(255,0,100)
            hl.FillTransparency = (Opt("ChamsWallTransp") or 40) / 100
        end
    end
end

local function RestoreChams(char)
    if not char then return end
    local saved = ChammedChars[char]
    if saved then
        for obj, orig in pairs(saved) do
            if obj and obj.Parent then
                pcall(function()
                    obj.Color        = orig.Color
                    obj.Material     = orig.Material
                    obj.Transparency = orig.Transparency
                end)
            end
        end
        ChammedChars[char] = nil
    end

    local hl = ChamsHighlights[char]
    if hl and hl.Parent then
        hl:Destroy()
    end
    ChamsHighlights[char] = nil
end

local function UpdateChams()
    local chamsOn = Get("ChamsEnabled")
    local teamChk = Get("ChamsTeamCheck")

    -- Rebuild if settings changed
    if _G.ChamsRebuild then
        _G.ChamsRebuild = false
        for char, _ in pairs(ChammedChars) do
            ChammedChars[char] = nil
        end
        for char, hl in pairs(ChamsHighlights) do
            if hl and hl.Parent then hl:Destroy() end
            ChamsHighlights[char] = nil
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end

        local char = player.Character
        if not char then continue end

        local isTeam = LP.Team ~= nil and player.Team == LP.Team

        local shouldChams = chamsOn
            and IsPlayerAlive(player)
            and not (teamChk and isTeam)

        if shouldChams then
            -- Apply chams if not yet applied
            if not ChammedChars[char] then
                SaveAndApplyChams(char)
            end
        else
            -- Remove chams if applied
            if ChammedChars[char] then
                RestoreChams(char)
            end
        end
    end
end

