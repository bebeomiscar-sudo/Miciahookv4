-- MAIN LOOP
-- ============================================================
local InterceptedCount = 0
local UpdateConn = RunService.RenderStepped:Connect(function(dt)
    if bc.Unloaded then return end

    local myChar = LP.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

    -- â”€â”€ HITBOX VISUAL â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if Get("HitboxEnabled") and Get("HitboxVisualise") and myRoot then
        local vis = GetHitboxVisual()
        local r   = Opt("HitboxRadius") or 15
        vis.Size   = Vector3.new(r*2, r*2, r*2)
        vis.CFrame = CFrame.new(myRoot.Position)
    else
        DestroyHitboxVisual()
    end

    -- â”€â”€ PER-WEAPON BYPASS + HITBOX LOOP â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    local function ProcessActiveTable(active, owners, prefix, countLbl, statusLbl)
        local count = 0
        local bypassOn = Get(prefix.."BypassEnabled")
        local hitboxOn = Get("HitboxEnabled")
        local applyHB  = hitboxOn and (Get("HitboxAllWeapons") or Get("Hitbox"..prefix))

        pcall(function()
            for part, data in pairs(active) do
                if not part or not part.Parent then
                    active[part]=nil; owners[part]=nil; continue
                end
                count = count + 1
                local owner = owners[part]

                -- BYPASS per-frame homing maintenance
                if bypassOn and data.Done then
                    local m   = Opt(prefix.."BypassMethod") or "Combined"
                    local spd = Opt(prefix.."HomingSpeed") or 999
                    local pred= Get(prefix.."HomingPrediction")
                    local team= Get(prefix.."TeamCheck")
                    local rd  = Get(prefix.."RedirectToOwner")
                    local own = Get(prefix.."OwnProjHoming")
                    if (m=="Homing" or m=="Combined") and Get(prefix.."HomingEnabled") and owner ~= LP then
                        DoHoming(part, owner, spd, pred, team, rd, own)
                    end
                    if (m=="Invisible" or m=="Combined") and Get(prefix.."InvisEnabled") and owner ~= LP then
                        if part.Transparency ~= 1 then
                            pcall(function() part.Transparency=1; part.CanCollide=false end)
                        end
                    end
                end

                -- HITBOX EXPANDER
                if applyHB then
                    if owner == LP then
                        -- OWN projectile: silent aim + snap
                        SilentAimRedirect(part)
                    else
                        -- ENEMY projectile: expanded nullify radius
                        if myRoot then ExpandedEnemyCheck(part, owner) end
                    end
                end

                -- Dagger-specific: destroy if stopped (embedded in wall)
                if prefix == "Dagger" and Get("DaggerDestroyOnImpact") and data.Done and owner ~= LP then
                    pcall(function()
                        if part.AssemblyLinearVelocity.Magnitude < 5 then
                            part:Destroy(); active[part]=nil; owners[part]=nil
                        end
                    end)
                end

                -- Infinite range maintenance: keep homing active forever
                if Get(prefix.."InfiniteRange") and data.Done and owner ~= LP and bypassOn then
                    local spd = Opt(prefix.."HomingSpeed") or 999
                    local pred= Get(prefix.."HomingPrediction")
                    local team= Get(prefix.."TeamCheck")
                    local rd  = Get(prefix.."RedirectToOwner")
                    DoHoming(part, owner, spd, pred, team, rd, false)
                end

                -- Expire after 30s (extended for infinite range)
                if tick()-data.SpawnTime > 30 then
                    active[part]=nil; owners[part]=nil
                end
            end
        end)

        if countLbl then countLbl:SetText(prefix=="Sling" and "Projectiles: "..count or prefix=="Bow" and "Arrows: "..count or "Daggers: "..count) end
        if statusLbl then statusLbl:SetText(count > 0 and "Bypass: Active âœ“" or "Bypass: Idle") end
    end

    ProcessActiveTable(SlingActive,  SlingOwners,  "Sling",  SlingProjLbl,  SlingStatusLbl)
    ProcessActiveTable(BowActive,    BowOwners,    "Bow",    BowProjLbl,    BowStatusLbl)
    ProcessActiveTable(DaggerActive, DaggerOwners, "Dagger", DaggerProjLbl, DaggerStatusLbl)

    HitboxRangeLbl:SetText("Expand Radius: "..(Opt("HitboxRadius") or 15).." studs")

    -- â”€â”€ ORBIT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if Get("OrbitEnabled") and #OrbitParts > 0 and myRoot then
        local speed=Opt("OrbitSpeed") or 2; local radius=Opt("OrbitRadius") or 6
        local height=Opt("OrbitHeight") or 0; local tilt=Opt("OrbitTilt") or 0
        local sz=Opt("OrbitSize") or 1; local intercR=Opt("InterceptRadius") or 2
        local glowOn=Get("OrbitGlow"); local visible=Get("OrbitVisible")
        local transp=visible and (Opt("OrbitTransparency") or 0)/100 or 1
        OrbitAngle=OrbitAngle+speed*dt
        local rootCF=myRoot.CFrame
        for _, data in ipairs(OrbitParts) do
            local part=data.Part
            if not part or not part.Parent then continue end
            local worldPos=GetOrbitPosition(data,OrbitAngle,rootCF,radius,height,tilt)
            local col=GetOrbitColor(data,OrbitAngle)
            part.Size=Vector3.new(sz,sz,sz); part.Color=col
            part.Material=glowOn and Enum.Material.Neon or Enum.Material.SmoothPlastic
            part.Transparency=transp; part.CFrame=CFrame.new(worldPos)
            local light=part:FindFirstChildOfClass("PointLight")
            if light then light.Color=col end
            if Get("OrbitIntercept") then
                for _, activeTable in ipairs({SlingActive,BowActive,DaggerActive}) do
                    for proj in pairs(activeTable) do
                        if not proj or not proj.Parent then continue end
                        local pOwner=SlingOwners[proj] or BowOwners[proj] or DaggerOwners[proj]
                        if pOwner==LP then continue end
                        if (proj.Position-worldPos).Magnitude <= intercR then
                            pcall(function() proj:Destroy() end)
                            SlingActive[proj]=nil; SlingOwners[proj]=nil
                            BowActive[proj]=nil;   BowOwners[proj]=nil
                            DaggerActive[proj]=nil; DaggerOwners[proj]=nil
                            InterceptedCount=InterceptedCount+1
                            InterceptLbl:SetText("Intercepted: "..InterceptedCount)
                            local orig=part.Color; part.Color=Color3.new(1,1,0)
                            task.delay(0.1,function() if part and part.Parent then part.Color=orig end end)
                        end
                    end
                end
            end
        end
        OrbitStatusLbl:SetText("Orbit Parts: "..#OrbitParts)
    end
end)

