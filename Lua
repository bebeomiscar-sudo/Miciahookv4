-- [[ CHAMS SYSTEM ]]
-- ============================================================
local ChammedData = {}

local function GetMaterialEnum(style)
    local map = {
        Neon          = Enum.Material.Neon,
        Glass         = Enum.Material.Glass,
        ForceField    = Enum.Material.ForceField,
        CrackedLava   = Enum.Material.CrackedLava,
        SmoothPlastic = Enum.Material.SmoothPlastic,
    }
    return map[style] or Enum.Material.Neon
end

local function ApplyChamsToChar(char)
    if ChammedData[char] then return end

    local style     = Opt("ChamsStyle") or "Neon"
    local visColor  = Options["ChamsVisColor"].Value  or Color3.fromRGB(0,200,255)
    local transp    = (Opt("ChamsTransparency") or 30) / 100
    local matEnum   = GetMaterialEnum(style)

    ChammedData[char] = {}

    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then
            ChammedData[char][obj] = {
                Color        = obj.Color,
                Material     = obj.Material,
                Transparency = obj.Transparency,
            }
            pcall(function()
                obj.Material     = matEnum
                obj.Color        = visColor
                obj.Transparency = transp
            end)
        end
    end

    -- Wallhack highlight
    if not char:FindFirstChild("_ChamHL") then
        local hl                  = Instance.new("Highlight")
        hl.Name                   = "_ChamHL"
        hl.FillColor              = Options["ChamsWallColor"].Value or Color3.fromRGB(255,0,100)
        hl.FillTransparency       = 0.4
        hl.OutlineTransparency    = 1
        hl.DepthMode              = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee                = char
        hl.Parent                 = char
    end
end

local function RemoveChamsFromChar(char)
    local data = ChammedData[char]
    if not data then return end

    for obj, orig in pairs(data) do
        if obj and obj.Parent then
            pcall(function()
                obj.Color        = orig.Color
                obj.Material     = orig.Material
                obj.Transparency = orig.Transparency
            end)
        end
    end

    local hl = char:FindFirstChild("_ChamHL")
    if hl then hl:Destroy() end

    ChammedData[char] = nil
end

local function UpdateChams()
    local chamsOn = Get("ChamsEnabled")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = player.Character
        if not char then continue end

        if chamsOn and IsAlive(player) then
            if not ChammedData[char] then
                ApplyChamsToChar(char)
            end
        else
            if ChammedData[char] then
                RemoveChamsFromChar(char)
            end
        end
    end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c)
        c:WaitForChild("HumanoidRootPart")
        task.wait(0.1)
        if Get("ChamsEnabled") then
            ApplyChamsToChar(c)
        end
    end)
end)

Players.PlayerRemoving:Connect(function(p)
    local c = p.Character
    if c and ChammedData[c] then RemoveChamsFromChar(c) end
    RemoveESP(p)
end)

