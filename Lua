local WeatherParts  = {}
local WeatherSound  = Instance.new("Sound")
WeatherSound.Looped = true
WeatherSound.Volume = 0.8
WeatherSound.Parent = workspace

function ApplyWeather(weatherType)
    -- Cleanup existing
    for _, p in ipairs(WeatherParts) do
        if p and p.Parent then p:Destroy() end
    end
    table.clear(WeatherParts)
    WeatherSound:Stop()

    if weatherType == "Rain" then
        WeatherSound.SoundId = "rbxassetid://9064263922"
        WeatherSound:Play()
    elseif weatherType == "Snow" then
        WeatherSound.SoundId = "rbxassetid://238895410"
        WeatherSound:Play()
    end
end

local function SpawnWeatherParticle()
    local char = GetChar()
    if not char then return end
    local root = GetRoot()
    if not root then return end

    local weatherType = getgenv().WeatherType

    if weatherType == "Rain" then
        local density = getgenv().RainDensity or 600
        if #WeatherParts >= density then return end

        local rainPart           = Instance.new("Part")
        rainPart.Anchored        = true
        rainPart.CanCollide      = false
        rainPart.Color           = getgenv().RainColor or Color3.fromRGB(255,255,255)
        rainPart.Material        = Enum.Material.Glass
        rainPart.Size            = Vector3.new(0.05, 1, 0.05)
        rainPart.Transparency    = 0.1
        rainPart.CastShadow      = false
        rainPart.Parent          = workspace

        local spawnRange = 50
        local startPos = root.Position + Vector3.new(
            (math.random() - 0.5) * spawnRange * 2,
            20 + math.random() * 10,
            (math.random() - 0.5) * spawnRange * 2
        )
        rainPart.CFrame = CFrame.new(startPos)
        table.insert(WeatherParts, rainPart)

        -- Fall down
        local speed = getgenv().RainSpeed or 150
        task.spawn(function()
            while rainPart and rainPart.Parent do
                rainPart.CFrame = rainPart.CFrame + Vector3.new(0, -speed * 0.016, 0)
                if rainPart.Position.Y < root.Position.Y - 10 then
                    -- Reset to top
                    rainPart.CFrame = CFrame.new(
                        root.Position + Vector3.new(
                            (math.random() - 0.5) * spawnRange * 2,
                            20 + math.random() * 5,
                            (math.random() - 0.5) * spawnRange * 2
                        )
                    )
                end
                task.wait(0.016)
            end
        end)

    elseif weatherType == "Snow" then
        local density = getgenv().SnowDensity or 250
        if #WeatherParts >= density then return end

        local sz              = 0.2
        local snowPart        = Instance.new("Part")
        snowPart.Anchored     = true
        snowPart.CanCollide   = false
        snowPart.Shape        = Enum.PartType.Ball
        snowPart.Color        = getgenv().SnowColor or Color3.fromRGB(255,255,255)
        snowPart.Material     = Enum.Material.Neon
        snowPart.Size         = Vector3.new(sz, sz, sz)
        snowPart.Transparency = 0.2
        snowPart.CastShadow   = false
        snowPart.Parent       = workspace

        local spawnRange = 50
        local startPos = root.Position + Vector3.new(
            (math.random() - 0.5) * spawnRange * 2,
            15 + math.random() * 10,
            (math.random() - 0.5) * spawnRange * 2
        )
        snowPart.CFrame = CFrame.new(startPos)
        table.insert(WeatherParts, snowPart)

        local speed = getgenv().SnowSpeed or 30
        task.spawn(function()
            while snowPart and snowPart.Parent do
                snowPart.CFrame = snowPart.CFrame * CFrame.new(
                    math.sin(tick() + snowPart.Position.X) * 0.03,
                    -speed * 0.016,
                    math.cos(tick() + snowPart.Position.Z) * 0.03
                )
                if snowPart.Position.Y < root.Position.Y - 5 then
                    snowPart.CFrame = CFrame.new(
                        root.Position + Vector3.new(
                            (math.random() - 0.5) * spawnRange * 2,
                            15 + math.random() * 5,
                            (math.random() - 0.5) * spawnRange * 2
                        )
                    )
                end
                task.wait(0.016)
            end
        end)
    end
end

-- ============================================================
-- [[ MOVEMENT SYSTEM ]]
-- AutoJump + AirStrafe + QuickStop
-- ============================================================
local function SetupMovement(char)
    if not char then return end

    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    RunService.Heartbeat:Connect(function()
        if not char.Parent then return end

        if getgenv().AutoJumpEnabled then
            if hum.FloorMaterial ~= Enum.Material.Air then
                hum.Jump = true
            end
        end

        if getgenv().AirStrafeEnabled then
            if hum.FloorMaterial == Enum.Material.Air then
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude > 0.856 then
                    root.AssemblyLinearVelocity = Vector3.new(
                        moveDir.X * getgenv().AirStrafeStrength,
                        root.AssemblyLinearVelocity.Y,
                        moveDir.Z * getgenv().AirStrafeStrength
                    )
                end
            end
        end

        if getgenv().QuickStopEnabled then
            local vel = root.AssemblyLinearVelocity
            if Vector3.new(vel.X, 0, vel.Z).Magnitude < 0.1
                and hum.MoveDirection.Magnitude < 0.1 then
                root.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
            end
        end
    end)
end

LP.CharacterAdded:Connect(SetupMovement)
if LP.Character then SetupMovement(LP.Character) end

-- ============================================================
-- [[ SPINBOT (YAW) ]]
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    if not getgenv().SpinbotEnabled then return end
    local root = GetRoot()
    if not root then return end

    root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(
        Camera.CFrame.LookVector.X,
        0,
        Camera.CFrame.LookVector.Z
    )) * CFrame.Angles(0, math.rad(tick() * 360 % 360), 0)
end)

