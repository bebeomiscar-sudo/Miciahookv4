-- ============================================================
-- [[ HELPERS ]]
-- ============================================================
local function Get(t)  return Toggles[t] and Toggles[t].Value or false end
local function Opt(o)  return Options[o]  and Options[o].Value end

local function GetChar()   return LP.Character end
local function GetRoot()
    local c = GetChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function IsPlayerAlive(player)
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function CanSee(fromPos, toPos)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local c = GetChar()
    params.FilterDescendantsInstances = c and { c } or {}
    local dir    = toPos - fromPos
    local result = workspace:Raycast(fromPos, dir, params)
    if result then
        return result.Instance and
               result.Instance.Parent and
               result.Instance.Parent:FindFirstChildOfClass("Humanoid") ~= nil
    end
    return true
end

local function GetBonePart(char, boneName)
    return char:FindFirstChild(boneName)
        or char:FindFirstChild("HumanoidRootPart")
end

-- Predict future position of a part
local function PredictPosition(part, scale)
    local vel  = part.AssemblyLinearVelocity
    local dist = (part.Position - Camera.CFrame.Position).Magnitude
    local t    = dist / math.max(300, 1)
    return part.Position + vel * t * (scale / 5)
end

-- ============================================================
-- [[ GET VALID ENEMIES ]]
-- ============================================================
local function GetEnemies(teamCheck, visCheck, boneName, maxDist)
    local list   = {}
    local myChar = GetChar()
    if not myChar then return list end
    local myRoot = GetRoot()
    if not myRoot then return list end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if not IsPlayerAlive(player) then continue end

        local char = player.Character
        if not char then continue end

        if teamCheck and LP.Team and player.Team == LP.Team then continue end

        local part = GetBonePart(char, boneName or "Head")
        if not part then continue end

        local dist = (part.Position - myRoot.Position).Magnitude
        if maxDist and dist > maxDist then continue end

        if visCheck then
            if not CanSee(myRoot.Position, part.Position) then continue end
        end

        table.insert(list, {
            Player    = player,
            Character = char,
            Part      = part,
            Distance  = dist,
        })
    end

    return list
end

-- Get closest enemy inside FOV circle on screen
local function GetClosestOnScreen(fovRadius, boneName, teamCheck, visCheck, maxDist)
    local center   = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestDist = math.huge
    local bestData = nil

    local enemies = GetEnemies(teamCheck, visCheck, boneName, maxDist)
    for _, data in ipairs(enemies) do
        local sp, onScreen = Camera:WorldToViewportPoint(data.Part.Position)
        if not onScreen then continue end

        local d2 = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d2 <= fovRadius and d2 < bestDist then
            bestDist = d2
            bestData = data
        end
    end

    return bestData
end

-- ============================================================
-- [[ BULLET HANDLER HOOK ]]
-- ============================================================
local function HookBulletHandler()
    if BHHooked then return end
    if not BulletHandler or not BulletHandler.Fire then
        warn("[creep.cc] BulletHandler not found")
        return
    end

    OriginalBHFire = BulletHandler.Fire

    BulletHandler.Fire = function(p6)
        -- Always capture weapon data from real shots
        if p6 then
            if p6.Network then CapturedNetwork = p6.Network end
            if p6.Visuals  then CapturedVisuals = p6.Visuals  end
            if p6.Logic    then CapturedLogic   = p6.Logic    end
            if p6.Misc     then CapturedMisc    = p6.Misc     end
        end

        -- ===================================================
        -- SILENT AIM: redirect direction toward target
        -- ===================================================
        if getgenv().SilentAimEnabled and p6 and p6.Origin then
            -- Hit chance check
            local hitChance = Opt("HitChance") or 100
            local roll      = math.random(1, 100)

            if roll <= hitChance then
                local fov      = Opt("SilentAimFOV")      or 250
                local bone     = Opt("SilentAimBone")     or "Head"
                local teamChk  = Get("SilentAimTeamCheck")
                local visChk   = Get("SilentAimVisCheck")
                local maxDist  = Opt("SilentAimMaxDist")  or 500
                local smooth   = Opt("SilentAimSmoothing")or 1
                local predict  = Get("SilentAimPrediction")
                local predSc   = Opt("SilentAimPredictScale") or 5

                local target = GetClosestOnScreen(fov, bone, teamChk, visChk, maxDist)

                if target and target.Part then
                    local targetPos = predict
                        and PredictPosition(target.Part, predSc)
                        or  target.Part.Position

                    local rawDir   = (targetPos - p6.Origin).Unit

                    -- Legit smoothing: lerp direction slightly
                    if smooth > 1 then
                        local currentDir = p6.Direction
                        rawDir = currentDir:Lerp(rawDir, 1 / smooth)
                    end

                    p6.Direction = rawDir
                end
            end
        end

        return OriginalBHFire(p6)
    end

    BHHooked = true
    print("[creep.cc] BulletHandler.Fire hooked")
end

-- ============================================================
-- [[ PROJECTILE RENDER HOOK ]]
-- For disabling/modifying original tracers
-- ============================================================
local function HookProjectileRender()
    if PRHooked then return end
    if not ProjectileRender or not ProjectileRender.Cast then
        warn("[creep.cc] ProjectileRender not found")
        return
    end

    OriginalPRCast = ProjectileRender.Cast

    ProjectileRender.Cast = function(self, data)
        -- If DisableTracers is on, skip original tracer
        if Get("TracerEnabled") and Get("TracerDisableOriginal") then
            return
        end
        return OriginalPRCast(self, data)
    end

    PRHooked = true
    print("[creep.cc] ProjectileRender.Cast hooked")
end

