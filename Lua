    sound.Volume = killVolume / 100
    sound.Pitch = killPitch / 100
    sound.Parent = Camera
    sound:Play()
    task.wait(sound.TimeLength)
    sound:Destroy()
end

-- Hook kill event
local function hookKill()
    local killRemote = ReplicatedStorage:FindFirstChild("Kill")
    if killRemote then
        killRemote.OnClientEvent = function()
            playKillSound()
        end
    end
end
