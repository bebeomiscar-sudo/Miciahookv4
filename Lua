-- [[ BULLET ID GENERATOR ]]
-- ============================================================
local function NewBulletId()
    return math.random(100000, 999999)
end

-- ============================================================
-- [[ BULLETHANDLER HOOK ]]
-- From DEX: BulletHandler.Fire takes a data table
-- We intercept and modify Direction for silent aim
-- We capture Network/Visuals/Logic/Misc for ragebot
-- ============================================================
local OriginalFire = nil
local HookActive   = false

local function HookBulletHandler()
    if HookActive then return end
    if not BulletHandler then
        warn("[creep.cc] BulletHandler module not found!")
        return
    end
    if not BulletHandler.Fire then
        warn("[creep.cc] BulletHandler.Fire not found!")
        return
    end

    OriginalFire = BulletHandler.Fire

    BulletHandler.Fire = function(p6)
        -- ===================================================
        -- Capture live data from real fire for ragebot to use
        -- ===================================================
        if p6 and p6.Network then
            CapturedNetwork = p6.Network
            CapturedVisuals = p6.Visuals
            CapturedLogic   = p6.Logic
            CapturedMisc    = p6.Misc
        end

        -- ===================================================
        -- NO SPREAD: zero out the spread value in Misc
        -- ===================================================
        if getgenv().NoSpread and p6.Misc then
            p6.Misc.Spread = 0
        end

        -- ===================================================
        -- NO RELOAD: set reload time to 0
        -- ===================================================
        if getgenv().NoReload and p6.Misc then
            p6.Misc.ReloadTime = 0
        end

        -- ===================================================
        -- INFINITE AMMO: set ammo to max
        -- ===================================================
        if getgenv().InfiniteAmmo and p6.Misc then
            p6.Misc.AmmoCount = p6.Misc.MaxAmmo or 9999
        end

        -- ===================================================
        -- SILENT AIM: redirect bullet direction to enemy
        -- ===================================================
        if getgenv().SilentAimEnabled and p6.Origin then
            local fov      = Opt("SilentAimFOV") or 250
            local bone     = Opt("SilentAimBone") or "Head"
            local teamChk  = Get("SilentAimTeamCheck")
            local visChk   = Get("SilentAimVisCheck")

            local target = GetClosestEnemyOnScreen(fov, bone, teamChk, visChk)
            if target and target.Part then
                -- Redirect direction to target bone
                local newDir    = (target.Part.Position - p6.Origin).Unit
                p6.Direction    = newDir
                -- Also update visual endpoint
                local visualEnd = p6.Origin + newDir * 800
                -- VisualOrigin stays same (muzzle position) for visual authenticity
            end
        end

        -- ===================================================
        -- Call original fire
        -- ===================================================
        return OriginalFire(p6)
    end

    HookActive = true
    print("[creep.cc] BulletHandler.Fire hooked successfully!")
end

task.spawn(HookBulletHandler)

-- ============================================================
-- [[ RAGEBOT ]]
-- Uses captured Network/Visuals/Logic/Misc from real fires
-- Calls BulletHandler.Fire for each enemy
-- ============================================================
local LastRagebotTime = 0
local IsRagebotFiring = false

local function FireAtTarget(targetData, network, visuals, logic, misc)
    if not targetData or not targetData.Part then return end
    if not network then return end

    local myChar = GetChar()
    if not myChar then return end

    local myRoot = GetRoot()
    if not myRoot then return end

    local part      = targetData.Part
    local origin    = myRoot.Position + Vector3.new(0, 1.5, 0)
    local direction = (part.Position - origin).Unit
    local hitsPerTarget = math.floor(Opt("RagebotHitsPerTarget") or 1)
    local fireDelay     = (Opt("RagebotDelay") or 50) / 1000

    for _ = 1, hitsPerTarget do
        -- Build fire data based on DEX BulletHandler.Fire signature
        local fireData = {
            Origin        = origin,
            VisualOrigin  = origin,
            Direction     = direction,
            Force         = (misc and misc.Force) or Vector3.new(0, 0, 0),
            Gravity       = (misc and misc.Gravity) or Vector3.new(0, -196.2, 0),
            BulletId      = NewBulletId(),
            Visuals       = visuals or {
                BulletType = nil,
                HitEffect  = nil,
            },
            Logic         = logic or {
                HitSound       = nil,
                HitMarker      = nil,
                IsExplosive    = false,
                ExplosionRadius= 0,
                ExplosionColor = Color3.new(1, 0.5, 0),
                ExplosionSoundId = nil,
                IsLaser        = false,
                LaserColor     = Color3.new(1, 0, 0),
                LaserWidth     = 0.1,
                LaserTime      = 0.5,
                LaserTexture   = nil,
                LaserSpeed     = 100,
                LaserLength    = 10,
                LaserEmission  = 1,
            },
            Network = network,
            Misc    = {
                AmmoCount  = getgenv().InfiniteAmmo and 9999 or (misc and misc.AmmoCount or 30),
                Spread     = getgenv().NoSpread and 0 or (misc and misc.Spread or 0),
                MaxAmmo    = misc and misc.MaxAmmo or 9999,
                ReloadTime = getgenv().NoReload and 0 or (misc and misc.ReloadTime or 2),
                CamCFrame  = Camera.CFrame,
                NewSeed    = math.random(1, 999999),
            }
        }

        -- Fire through hooked function
        pcall(function()
            OriginalFire(fireData)
        end)

        if fireDelay > 0 then
            task.wait(fireDelay)
        end
    end
end

local function RunRagebot()
    if IsRagebotFiring then return end
    if not CapturedNetwork then return end

    local bone      = Opt("RagebotBone") or "Head"
    local teamChk   = Get("RagebotTeamCheck")
    local visChk    = Get("RagebotVisCheck")
    local enemies   = GetEnemies(teamChk, visChk, bone)

    if #enemies == 0 then return end

    IsRagebotFiring = true

    task.spawn(function()
        for _, enemyData in ipairs(enemies) do
            FireAtTarget(
                enemyData,
                CapturedNetwork,
                CapturedVisuals,
                CapturedLogic,
                CapturedMisc
            )
        end
        IsRagebotFiring = false
    end)
end

-- ============================================================
-- [[ ANTI AIM SYSTEM ]]
-- Rotates specific body parts to confuse hitboxes
-- Parts: Head, Torso, LeftArm, LeftLowerArm,
--        LeftUpperArm, LeftUpperLeg
-- ============================================================
local AntiAimParts       = {}
local AntiAimOriginalC0  = {}
local AntiAimConnections = {}

-- Build part reference table
local function BuildAntiAimParts(char)
    if not char then return end

    -- Part Name → Motor6D/Joint locations
    local partNames = {
        "Head",
        "Torso",
        "UpperTorso",
        "LeftArm",
        "LeftLowerArm",
        "LeftUpperArm",
        "LeftUpperLeg",
    }

    local joints = {}
    for _, desc in ipairs(char:GetDescendants()) do
        if desc:IsA("Motor6D") then
            joints[#joints + 1] = desc
        end
    end

    AntiAimParts[char]       = {}
    AntiAimOriginalC0[char]  = {}

    for _, jointName in ipairs(partNames) do
        for _, motor in ipairs(joints) do
            if motor.Part1 and motor.Part1.Name == jointName then
                AntiAimParts[char][jointName]       = motor
                AntiAimOriginalC0[char][jointName]  = motor.C0
            end
        end
    end
end

function RestoreAntiAim()
    local char = GetChar()
    if not char then return end
    if not AntiAimParts[char] then return end

    for partName, motor in pairs(AntiAimParts[char]) do
        if motor and motor.Parent then
            local orig = AntiAimOriginalC0[char][partName]
            if orig then
                pcall(function() motor.C0 = orig end)
            end
        end
    end
end

local AntiAimAngle    = 0
local RandomAngle1    = math.random(-180, 180)
local RandomAngle2    = math.random(-180, 180)
local LastRandomTime  = 0
local RandomInterval  = 0.1

local function GetAntiAimAngles()
    local mode     = getgenv().AntiAimMode or "Random 1"
    local upAng    = getgenv().AntiAimUpAngle   or 0
    local downAng  = getgenv().AntiAimDownAngle or 0

    -- X = pitch (up/down), Y = yaw (left/right), Z = roll
    if mode == "Random 1" then
        -- Random spin on all axes
        local now = tick()
        if now - LastRandomTime > RandomInterval then
            RandomAngle1 = math.random(-180, 180)
            LastRandomTime = now
        end
        return math.rad(RandomAngle1), math.rad(RandomAngle1 * 0.5), 0

    elseif mode == "Random 2" then
        -- Rapid flip random
        local now = tick()
        if now - LastRandomTime > 0.05 then
            RandomAngle2 = math.random() < 0.5 and 180 or -180
            LastRandomTime = now
        end
        return math.rad(RandomAngle2), 0, math.rad(RandomAngle2)

    elseif mode == "Down" then
        -- Force pitch downward
        return math.rad(90 + downAng * 10), 0, 0

    elseif mode == "Up" then
        -- Force pitch upward
        return math.rad(-(90 + upAng * 10)), 0, 0

    elseif mode == "Custom" then
        -- Blend up and down
        local pitchUp   = math.rad(upAng   * 10)
        local pitchDown = math.rad(downAng * 10)
        local combined  = pitchUp - pitchDown
        return combined, 0, 0
    end

    return 0, 0, 0
end

local function ApplyAntiAim(char)
    if not char then return end
    if not AntiAimParts[char] then
        BuildAntiAimParts(char)
    end

    local pitchX, yawY, rollZ = GetAntiAimAngles()

    -- Apply to each targeted part
    local partAngles = {
        Head          = CFrame.Angles(pitchX,         yawY,          rollZ),
        Torso         = CFrame.Angles(pitchX * 0.5,   yawY,          0),
        UpperTorso    = CFrame.Angles(pitchX * 0.5,   yawY,          0),
        LeftArm       = CFrame.Angles(pitchX,         0,             rollZ * 0.5),
        LeftLowerArm  = CFrame.Angles(pitchX * 0.7,   0,             0),
        LeftUpperArm  = CFrame.Angles(pitchX * 0.8,   yawY * 0.5,    0),
        LeftUpperLeg  = CFrame.Angles(pitchX * 0.6,   0,             rollZ * 0.3),
    }

    for partName, angleOffset in pairs(partAngles) do
        local motor = AntiAimParts[char] and AntiAimParts[char][partName]
        if motor and motor.Parent then
            local origC0 = AntiAimOriginalC0[char] and AntiAimOriginalC0[char][partName]
            if origC0 then
                pcall(function()
                    motor.C0 = origC0 * angleOffset
                end)
            end
        end
    end
end

-- Rebuild anti aim when character respawns
LP.CharacterAdded:Connect(function(char)
    table.clear(AntiAimParts)
    table.clear(AntiAimOriginalC0)
    task.wait(0.5)
    BuildAntiAimParts(char)
end)

if LP.Character then
    task.spawn(function()
        task.wait(0.5)
        BuildAntiAimParts(LP.Character)
    end)
end

