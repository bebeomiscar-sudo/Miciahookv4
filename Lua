-- ========== SILENT AIM ==========
local SilentSection = Combat:CreateSection("Silent Aim")
local silentEnabled = false
local silentHitPart = "Head"
local silentFOV = 100
local silentHitChance = 100
local backshoot = false
local antiKatana = false

local function silentAimFire(originalFunc, ...)
    if not silentEnabled then return originalFunc(...) end
    local target = getNearestPlayer(silentFOV, silentHitPart)
    if target and target.Character then
        local hitPartObj = getPartFromPlayer(target, silentHitPart)
        if hitPartObj and (math.random(100) <= silentHitChance) then
            -- Override the hit point
            return originalFunc(hitPartObj.Position, ...)
        end
    end
    return originalFunc(...)
end

-- Hook weapon fire (example for typical Rivals)
local function hookWeaponFire()
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("Fire") then
        local oldFire = tool.Fire
        tool.Fire = function(...) return silentAimFire(oldFire, ...) end
    end
end
