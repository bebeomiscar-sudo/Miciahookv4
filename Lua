        espDrawings[player].dist = Drawing.new("Text")
        espDrawings[player].dist.Size = espDistSize
        espDrawings[player].dist.Center = true
    end
    if type == "health" and not espDrawings[player].health then
        espDrawings[player].health = Drawing.new("Line")
        espDrawings[player].health.Thickness = 3
    end
    if type == "tracer" and not espDrawings[player].tracer then
        espDrawings[player].tracer = Drawing.new("Line")
        espDrawings[player].tracer.Thickness = espTracerThick
    end
    if type == "skeleton" and not espDrawings[player].skeleton then
