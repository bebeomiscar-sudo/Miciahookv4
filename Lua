-- ============================================================
-- [[ HELPERS ]]
-- ============================================================
local function Get(t)  return Toggles[t] and Toggles[t].Value end
local function Opt(o)  return Options[o]  and Options[o].Value  end

local function GetChar()
    return LP.Character
end

local function GetRoot()
    local c = GetChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function IsAlive(player)
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function CanSee(fromPos, toPos)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local myChar = GetChar()
    params.FilterDescendantsInstances = myChar and { myChar } or {}

    local dir    = toPos - fromPos
    local result = workspace:Raycast(fromPos, dir, params)
    if result then
        local inst = result.Instance
        if inst and inst.Parent then
            return inst.Parent:FindFirstChildOfClass("Humanoid") ~= nil
        end
        return false
    end
    return true
end

local function GetBonePart(char, boneName)
    return char:FindFirstChild(boneName)
        or char:FindFirstChild("HumanoidRootPart")
end

local function GetEnemies(teamCheckToggle, visCheckToggle, boneName)
    local enemies = {}
    local myChar  = GetChar()
    if not myChar then return enemies end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if not IsAlive(player) then continue end
        if teamCheckToggle and LP.Team and player.Team == LP.Team then continue end

        local char = player.Character
        if not char then continue end

        local part = GetBonePart(char, boneName or "Head")
        if not part then continue end

        if visCheckToggle then
            local root = GetRoot()
            if root and not CanSee(root.Position, part.Position) then continue end
        end

        table.insert(enemies, { Player = player, Character = char, Part = part })
    end

    return enemies
end

local function GetClosestEnemyOnScreen(fovRadius, boneName, teamCheck, visCheck)
    local center  = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestDist= math.huge
    local bestData= nil

    local enemies = GetEnemies(teamCheck, visCheck, boneName)
    for _, data in ipairs(enemies) do
        local part = data.Part
        local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        local dist2D = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if dist2D <= fovRadius and dist2D < bestDist then
            bestDist = dist2D
            bestData = data
        end
    end

    return bestData
end

