-- ============================================================
local AimbotTarget = nil

local function GetBestTarget()
    local myChar = GetChar()
    if not myChar then return nil end

    local fov    = getgenv().DynamicFOV
        and math.clamp(getgenv().Multiplier * Camera.FieldOfView / 70, 50, 500)
        or  getgenv().Multiplier

    local center   = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestPart = nil
    local bestDist = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = player.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local hitSel = getgenv().HitSelection

        local partsToCheck = {}
        if hitSel == "All" then
            for _, n in ipairs({"Head","UpperTorso","Torso","HumanoidRootPart"}) do
                local p = char:FindFirstChild(n)
                if p then table.insert(partsToCheck, p) end
            end
        else
            local p = char:FindFirstChild(hitSel)
            if p then table.insert(partsToCheck, p) end
        end

        for _, part in ipairs(partsToCheck) do
            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if not onScreen then continue end

            local sp   = Vector2.new(screenPos.X, screenPos.Y)
            local dist = (sp - center).Magnitude
            if dist <= fov and dist < bestDist then
                bestDist = dist
                bestPart = part
            end
        end
    end

    return bestPart
end

local function ApplyAimbot()
    if not getgenv().AimbotEnabled then return end

    AimbotTarget = GetBestTarget()
    if not AimbotTarget then return end

    local smooth = math.clamp(getgenv().Smooth, 1, 20)
    local targetCF = CFrame.lookAt(
        Camera.CFrame.Position,
        Camera.CFrame.Position + (AimbotTarget.Position - Camera.CFrame.Position).Unit
    )
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, 1 / smooth)
end

