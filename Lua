-- [[ BULLET TRACER ]]
-- Spawns a neon part + trail from muzzle to hit point
-- ============================================================
local function SpawnBulletTracer(fromPos, toPos)
    if not getgenv().TrailEnabled then return end

    local color    = getgenv().TrailColor or Color3.fromRGB(255, 50, 255)
    local lifetime = Opt("TracerLifetime") or 10
    local width    = Opt("TracerWidth") or 0.219

    local tracerPart        = Instance.new("Part")
    tracerPart.Anchored     = true
    tracerPart.CanCollide   = false
    tracerPart.CanQuery     = false
    tracerPart.CanTouch     = false
    tracerPart.Size         = Vector3.new(0.9, 0.5, 1)
    tracerPart.Color        = color
    tracerPart.Material     = Enum.Material.Neon
    tracerPart.CastShadow   = false
    tracerPart.Transparency = 0
    tracerPart.CFrame       = CFrame.new(fromPos)
    tracerPart.Parent       = workspace

    local a0          = Instance.new("Attachment")
    a0.Position       = Vector3.new(0, 0, -0.15)
    a0.Parent         = tracerPart

    local a1          = Instance.new("Attachment")
    a1.Position       = Vector3.new(0, 0, 0.15)
    a1.Parent         = tracerPart

    local trail             = Instance.new("Trail")
    trail.Attachment0       = a0
    trail.Attachment1       = a1
    trail.FaceCamera        = true
    trail.Lifetime          = lifetime
    trail.LightEmission     = 1
    trail.LightInfluence    = 0
    trail.Brightness        = 8
    trail.Color             = ColorSequence.new(color)
    trail.Transparency      = NumberSequence.new(0)
    trail.WidthScale        = NumberSequence.new({
        NumberSequenceKeypoint.new(0, width),
        NumberSequenceKeypoint.new(1, width),
    })
    trail.Enabled = true
    trail.Parent  = tracerPart

    -- Move tracer from fromPos to toPos
    task.spawn(function()
        local steps = 20
        for i = 1, steps do
            if not tracerPart.Parent then break end
            local t   = i / steps
            local pos = fromPos:Lerp(toPos, t)
            tracerPart.CFrame = CFrame.new(pos)
            task.wait(0.016)
        end
        Debris:AddItem(tracerPart, lifetime)
    end)
end

-- Hook projectile hits for tracer (using workspace DescendantAdded)
workspace.DescendantAdded:Connect(function(obj)
    if not getgenv().TrailEnabled then return end
    if not obj:IsA("BasePart") then return end
    -- Detect as projectile by name/velocity
    task.defer(function()
        if not obj or not obj.Parent then return end
        if obj.AssemblyLinearVelocity.Magnitude > 50 then
            local from = Camera.CFrame.Position
            local to   = obj.Position
            SpawnBulletTracer(from, to)
        end
    end)
end)

