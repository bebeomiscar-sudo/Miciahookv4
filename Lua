local SoulParts = {}

function CleanupSoulParticles()
    for _, p in ipairs(SoulParts) do
        if p and p.Parent then p:Destroy() end
    end
    table.clear(SoulParts)
end

local SoulAngle = 0

local function UpdateSoulParticles(dt)
    if not Get("SoulParticlesEnabled") then return end

    local char = GetChar()
    if not char then return end

    local root = GetRoot()
    if not root then return end

    local count = math.floor(Opt("SoulParticleCount") or 20)
    local sz    = Opt("SoulParticleSize") or 3
    local spd   = Opt("SoulParticleSpeed") or 30
    local col   = Options["SoulParticleColor"].Value or Color3.fromRGB(150, 0, 255)

    -- Spawn new particles up to count
    while #SoulParts < count do
        local p           = Instance.new("Part")
        p.Anchored        = true
        p.CanCollide      = false
        p.CanQuery        = false
        p.CanTouch        = false
        p.CastShadow      = false
        p.Shape           = Enum.PartType.Ball
        p.Size            = Vector3.new(sz * 0.3, sz * 0.3, sz * 0.3)
        p.Material        = Enum.Material.Neon
        p.Color           = col
        p.Transparency    = 0.2
        p.Parent          = workspace

        -- Add point light
        local pl          = Instance.new("PointLight")
        pl.Brightness     = 3
        pl.Range          = 6
        pl.Color          = col
        pl.Parent         = p

        local data = {
            Part       = p,
            Angle      = math.random() * math.pi * 2,
            Radius     = sz + math.random() * sz,
            HeightOff  = (math.random() - 0.5) * 4,
            AngSpeed   = (0.5 + math.random()) * (math.random() < 0.5 and 1 or -1),
            Phase      = math.random() * math.pi * 2,
            AliveTime  = 0,
            MaxLife    = 3 + math.random() * 5,
        }
        table.insert(SoulParts, data)
    end

    -- Update positions
    for i = #SoulParts, 1, -1 do
        local data = SoulParts[i]
        local p    = data.Part
        if not p or not p.Parent then
            table.remove(SoulParts, i)
            continue
        end

        data.AliveTime = data.AliveTime + dt
        data.Angle     = data.Angle + data.AngSpeed * dt * (spd / 30)

        local riseY   = data.AliveTime * 1.5
        local wobbleX = math.sin(data.Phase + data.AliveTime * 2) * 0.5
        local wobbleZ = math.cos(data.Phase + data.AliveTime * 2) * 0.5

        local newPos  = root.Position + Vector3.new(
            math.cos(data.Angle) * data.Radius + wobbleX,
            data.HeightOff + riseY,
            math.sin(data.Angle) * data.Radius + wobbleZ
        )

        -- Fade out near end of life
        local lifeRatio     = data.AliveTime / data.MaxLife
        p.Transparency      = math.clamp(0.2 + lifeRatio * 0.8, 0, 1)

        local light = p:FindFirstChildOfClass("PointLight")
        if light then
            light.Color = col
        end
        p.Color = col
        p.CFrame = CFrame.new(newPos)

        -- Remove expired particles
        if data.AliveTime >= data.MaxLife then
            p:Destroy()
            table.remove(SoulParts, i)
        end
    end
end

