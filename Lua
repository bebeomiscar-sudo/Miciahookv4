-- [[ NO SCOPE ZOOM ]]
-- ============================================================
local OrigFOV     = Camera.FieldOfView
local OrigZoomMinNS = LP.CameraMinZoomDistance
local OrigZoomMaxNS = LP.CameraMaxZoomDistance

RunService.RenderStepped:Connect(function()
    if not getgenv().NoScopeZoom then return end
    LP.CameraMinZoomDistance = OrigZoomMinNS
    LP.CameraMaxZoomDistance = OrigZoomMaxNS
    if Camera.FieldOfView ~= OrigFOV then
        Camera.FieldOfView = OrigFOV
    end
end)

-- ============================================================
-- [[ CHAMS UPDATE ]]
-- ============================================================
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(char)
        char:WaitForChild("HumanoidRootPart")
        task.wait(0.1)
        if getgenv().ChamsEnabled then
            ApplyChamsToChar(char)
        end
    end)
end)

Players.PlayerRemoving:Connect(function(player)
    local char = player.Character
    if char and OrigCharData[char] then
        RemoveChamsFromChar(char)
    end
    RemoveESPForPlayer(player)
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player == LP then continue end
    local char = player.Character
    if char and getgenv().ChamsEnabled then
        ApplyChamsToChar(char)
    end
    player.CharacterAdded:Connect(function(c)
        c:WaitForChild("HumanoidRootPart")
        task.wait(0.1)
        if getgenv().ChamsEnabled then
            ApplyChamsToChar(c)
        end
    end)
end

-- ============================================================
-- [[ MAIN RENDER LOOP ]]
-- ============================================================
local RenderConn = RunService.RenderStepped:Connect(function(dt)
    if bc.Unloaded then return end

    -- FOV Circle
    local fov = getgenv().DynamicFOV
        and math.clamp(getgenv().Multiplier * Camera.FieldOfView / 70, 50, 500)
        or  getgenv().Multiplier

    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    FOVCircle.Visible   = getgenv().DrawFOV
    FOVCircle.Position  = center
    FOVCircle.Radius    = fov
    FOVCircle.Color     = Options["FOVCircleColor"].Value or Color3.new(1,1,1)

    -- Trigger Circle
    TriggerCircle.Visible  = getgenv().ShowCircle and getgenv().TRIGGER_Enabled
    TriggerCircle.Position = center
    TriggerCircle.Radius   = getgenv().TriggerRadius

    -- Aimbot
    ApplyAimbot()

    -- Triggerbot
    RunTriggerbot()

    -- ESP
    UpdateESP()

    -- Soul Particles
    UpdateSoulParticles(dt)

    -- Weather spawning
    if getgenv().WeatherType ~= "None" then
        SpawnWeatherParticle()
    end

    -- Chams update
    if getgenv().ChamsEnabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            local char = player.Character
            if char and not ChammedChars[char] then
                ApplyChamsToChar(char)
            end
        end
    else
        for char in pairs(ChammedChars) do
            RemoveChamsFromChar(char)
        end
    end
end)

-- ============================================================
-- [[ UNLOAD ]]
-- ============================================================
bc:OnUnload(function()
    bc.Unloaded = true
    if RenderConn then RenderConn:Disconnect() end

    -- Restore lighting
    for k, v in pairs(OrigLighting) do
        Lighting[k] = v
    end

    -- Remove skybox
    local sky = Lighting:FindFirstChildOfClass("Sky")
    if sky then sky:Destroy() end

    -- Remove bloom
    local bloom = Lighting:FindFirstChild("NightBloom")
    if bloom then bloom:Destroy() end

    -- Cleanup ESP
    for _, player in ipairs(Players:GetPlayers()) do
        RemoveESPForPlayer(player)
        local char = player.Character
        if char then RemoveChamsFromChar(char) end
    end

    -- Cleanup soul particles
    CleanupSoulParticles()

    -- Cleanup weather
    for _, p in ipairs(WeatherParts) do
        if p and p.Parent then p:Destroy() end
    end
    table.clear(WeatherParts)
    WeatherSound:Stop()
    WeatherSound:Destroy()

    -- Restore camera
    ApplyThirdperson(false)
    Camera.FieldOfView = OrigFOV

    -- FOV/Trigger circles
    FOVCircle:Remove()
    TriggerCircle:Remove()

    print("[creep.cc] Rivals Flick Script unloaded.")
end)

return function() bc:Unload() end
