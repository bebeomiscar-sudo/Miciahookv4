                    local Key = KeyPicker.Value
                    if Key == 'MB1' or Key == 'MB2' then
                        if (Key == 'MB1' and Input.UserInputType == Enum.UserInputType.MouseButton1) or (Key == 'MB2' and Input.UserInputType == Enum.UserInputType.MouseButton2) then
