-- ============================================
-- UTILITY FUNCTIONS
-- ============================================
local function getNearestPlayer(maxDistance, hitPartName)
    local nearest = nil
    local shortest = maxDistance or 1e9
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(hitPartName or "Head") then
            local part = player.Character[hitPartName or "Head"]
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if dist < shortest then
                    shortest = dist
                    nearest = player
                end
            end
        end
    end
    return nearest
end

local function getPartFromPlayer(player, hitPart)
    if hitPart == "Random" then
        local parts = {"Head","HumanoidRootPart","UpperTorso","LowerTorso","LeftArm","RightArm","LeftLeg","RightLeg"}
        return player.Character[parts[math.random(#parts)]]
    elseif hitPart == "Closest" then
        local closest = nil
        local closestDist = math.huge
        for _, partName in pairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","LeftArm","RightArm","LeftLeg","RightLeg"}) do
            local part = player.Character:FindFirstChild(partName)
            if part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = part
                    end
                end
            end
        end
        return closest
    else
        return player.Character:FindFirstChild(hitPart) or player.Character:FindFirstChild("Head")
    end
end

