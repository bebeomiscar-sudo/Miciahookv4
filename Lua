-- [[ AIMBOT - CFRAME BASED ]]
-- Works on mobile and PC
-- Uses camera CFrame lerp toward target
-- ============================================================
local AimbotFOVCircle      = Drawing.new("Circle")
AimbotFOVCircle.NumSides   = 64
AimbotFOVCircle.Filled     = false

local function AimbotKeyActive()
    -- Always active mode (mobile)
    if Get("AimbotAlways") then return true end
    -- Key hold mode
    local key = Options["AimbotKey"]
    return key and key:GetState()
end

local function ApplyAimbot(dt)
    if not Get("AimbotEnabled") then return end
    if not AimbotKeyActive() then return end

    local fov      = Opt("AimbotFOV")      or 200
    local bone     = Opt("AimbotBone")     or "Head"
    local teamChk  = Get("AimbotTeamCheck")
    local visChk   = Get("AimbotVisCheck")
    local smooth   = Opt("AimbotSmoothing") or 10

    local target = GetClosestOnScreen(fov, bone, teamChk, visChk, nil)
    if not target or not target.Part then return end

    -- Smooth camera CFrame toward target (works on all devices)
    local camPos    = Camera.CFrame.Position
    local targetCF  = CFrame.lookAt(camPos, target.Part.Position)
    local alpha     = math.clamp(1 / smooth * dt * 60, 0.01, 1)

    Camera.CFrame   = Camera.CFrame:Lerp(targetCF, alpha)
end

