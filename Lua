-- ============================================================
-- HITBOX EXPANDER CORE
-- Strategy post-patch:
--   OWN projectiles  â†’ Silent Aim: steer OWN projectile toward
--     the nearest enemy's hitpart the moment it spawns, using
--     a configurable FOV cone. Then snap it onto the target
--     the moment it enters SnapDist â€” making it always hit.
--   ENEMY projectiles â†’ if they enter our expanded radius,
--     nullify or redirect them before server registers touch.
-- ============================================================
local HitboxExpandHits  = 0
local HitboxVisualPart  = nil

local function GetHitboxVisual()
    if HitboxVisualPart and HitboxVisualPart.Parent then return HitboxVisualPart end
    local p = Instance.new("Part")
    p.Name        = "_LogicHitboxVis"
    p.Anchored    = true
    p.CanCollide  = false
    p.CanQuery    = false
    p.CanTouch    = false
    p.CastShadow  = false
    p.Shape       = Enum.PartType.Ball
    p.Material    = Enum.Material.Neon
    p.Color       = Color3.fromRGB(255,50,50)
    p.Transparency= 0.7
    p.Parent      = workspace
    HitboxVisualPart = p
    return p
end

local function DestroyHitboxVisual()
    if HitboxVisualPart and HitboxVisualPart.Parent then
        HitboxVisualPart:Destroy()
        HitboxVisualPart = nil
    end
end

-- Silent Aim: for OWN projectile, redirect it toward nearest enemy
-- within FOV cone relative to camera look vector
local function SilentAimRedirect(part)
    if not Get("HitboxSilent") then return end
    local fov      = Opt("HitboxSilentFOV") or 180
    local halfFOV  = math.rad(fov / 2)
    local camLook  = Camera.CFrame.LookVector
    local partPos  = part.Position
    local best, bd = nil, math.huge

    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LP then continue end
        if Get("SlingTeamCheck") and LP.Team and pl.Team == LP.Team then continue end
        local ch2 = pl.Character; if not ch2 then continue end
        local hum = ch2:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local targetPart = ch2:FindFirstChild(Opt("HitboxTargetPart") or "HumanoidRootPart")
                        or ch2:FindFirstChild("Head")
        if not targetPart then continue end

        local toTarget = (targetPart.Position - partPos)
        local dist     = toTarget.Magnitude
        local angle    = math.acos(math.clamp(camLook:Dot(toTarget.Unit), -1, 1))

        if angle <= halfFOV and dist < bd then
            bd = dist; best = targetPart
        end
    end

    if not best then return end

    local snapDist = Opt("HitboxSnapDist") or 3
    local dist = (best.Position - partPos).Magnitude

    if dist <= snapDist then
        -- Snap the projectile directly onto the target
        pcall(function()
            part.CFrame = CFrame.new(best.Position)
            part.AssemblyLinearVelocity = Vector3.zero
        end)
        HitboxExpandHits = HitboxExpandHits + 1
        HitboxHitsLbl:SetText("Expanded Hits: "..HitboxExpandHits)
    else
        -- Steer aggressively toward target with infinite-range speed
        local spd = math.huge -- teleport-speed: use a very large number
        local dir = (best.Position - partPos).Unit
        pcall(function()
            part.AssemblyLinearVelocity = dir * 9999
        end)
    end
end

-- Enemy projectile expanded detection â€” nullify if within expanded radius
local function ExpandedEnemyCheck(part, owner)
    if not Get("HitboxEnabled") then return end
    if not Get("HitboxOnlyEnemy") or (owner and owner ~= LP) then
        local myChar = LP.Character; if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
        local expandR = Opt("HitboxRadius") or 15
        if (part.Position - myRoot.Position).Magnitude <= expandR then
            pcall(function() part:Destroy() end)
        end
    end
end

